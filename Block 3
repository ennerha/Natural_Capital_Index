def add_grid_lulc_indicators(feature):
    """Compute land-cover indicators for each grid cell."""
    geom   = feature.geometry()
    result = multi_baseline.reduceRegion(
        reducer=ee.Reducer.sum(), geometry=geom,
        scale=30, maxPixels=1e13, bestEffort=True
    )
    out = feature.set("total_area_ha_ee", result.get("total_area"))
    for g in CLASS_GROUPS.keys():
        area  = result.get(g)
        total = result.get("total_area")
        pct   = ee.Number(area).divide(ee.Number(total)).multiply(100)
        out   = out.set(f"{g}_ha_{BASELINE_YEAR}", area)
        out   = out.set(f"{g}_pct_{BASELINE_YEAR}", pct)
    return out


