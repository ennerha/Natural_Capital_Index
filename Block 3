def add_grid_change(feature):
    """Compute native vegetation and anthropic change per grid cell."""
    geom     = feature.geometry()
    res_base = multi_baseline.reduceRegion(
        reducer=ee.Reducer.sum(), geometry=geom, scale=30,
        maxPixels=1e13, bestEffort=True
    )
    res_1985 = multi_1985.reduceRegion(
        reducer=ee.Reducer.sum(), geometry=geom, scale=30,
        maxPixels=1e13, bestEffort=True
    )
    nv_base   = ee.Number(res_base.get("native_vegetation"))
    nv_1985   = ee.Number(res_1985.get("native_vegetation"))
    total     = ee.Number(res_base.get("total_area"))
    delta_ha  = nv_base.subtract(nv_1985)
    delta_pct = delta_ha.divide(total).multiply(100)

    return feature.set({
        "nv_ha_1985":          res_1985.get("native_vegetation"),
        "nv_ha_baseline":      res_base.get("native_vegetation"),
        "nv_delta_ha":         delta_ha,
        "nv_delta_pct":        delta_pct,
        "anthro_ha_1985":      res_1985.get("anthropic"),
        "anthro_ha_baseline":  res_base.get("anthropic"),
        "anthro_delta_ha":     ee.Number(res_base.get("anthropic"))
                               .subtract(ee.Number(res_1985.get("anthropic"))),
    })


