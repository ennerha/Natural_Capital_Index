def clip_image_to_aoi(image: ee.Image, aoi_geometry: ee.Geometry) -> ee.Image:
    """Clip and mask an ee.Image to the exact municipal boundary."""
    return (
        image
        .clip(aoi_geometry)
        .updateMask(ee.Image.constant(1).clip(aoi_geometry).unmask(0))
    )


def build_multiband_area_image(lulc_img: ee.Image) -> ee.Image:
    """
    Build a multiband image where each band holds the area (ha) of
    one class group. Allows computing all groups in a single
    reduceRegion call instead of N separate calls.
    """
    pixel_area_ha = ee.Image.pixelArea().divide(1e4)
    bands = []
    for group_name, classes in CLASS_GROUPS.items():
        mask = lulc_img.remap(classes, [1] * len(classes), 0)
        band = pixel_area_ha.updateMask(mask).rename(group_name)
        bands.append(band)
    bands.append(pixel_area_ha.rename("total_area"))
    return ee.Image.cat(bands)


def safe_float(x):
    try:
        return float(x) if x is not None else np.nan
    except Exception:
        return np.nan

# ------------------------------------------------------------
# 8. Annual land-cover trajectories — 1 API call per year (40 total)
# ------------------------------------------------------------
# One reduceRegion per year computes all class groups simultaneously,
# reducing API calls from ~400 (naive approach) to 40.

print(f"\nComputing annual land-cover trajectories {START_YEAR}–{END_YEAR}...")

records = []

for i, year in enumerate(YEARS):
    lulc  = clip_image_to_aoi(mapbiomas_raw.select(f"classification_{year}"), aoi_geom)
    multi = build_multiband_area_image(lulc)

    result = multi.reduceRegion(
        reducer=ee.Reducer.sum(),
        geometry=aoi_geom,
        scale=30, maxPixels=1e13, bestEffort=True
    ).getInfo()

    row = {"year": year}
    row["total_area_ha"] = safe_float(result.get("total_area"))
    for group_name in CLASS_GROUPS.keys():
        row[f"{group_name}_ha"] = safe_float(result.get(group_name))
    records.append(row)

    if (i + 1) % 10 == 0:
        print(f"  {i + 1}/{len(YEARS)} years processed...")

lulc_df = pd.DataFrame(records)

