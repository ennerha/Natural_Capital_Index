def _apply_map_extent(ax):
    """Force the axes to the precomputed municipal extent."""
    ax.set_xlim(MAP_XLIM)
    ax.set_ylim(MAP_YLIM)


def _apply_mask(ax):
    """
    Paint everything OUTSIDE the municipal boundary in white.
    This erases the rectangular edges of the grid and leaves only
    the true municipal shape visible.
    """
    mask_gdf.plot(ax=ax, color="white", linewidth=0, zorder=5)


def _draw_boundary(ax, lw=1.6):
    """
    Draw the municipal boundary outline.
    Two-pass: white halo first, then dark line for readability on any bg.
    """
    muni_boundary.boundary.plot(ax=ax, color="white",
                                linewidth=lw + 1.2, zorder=6, alpha=0.8)
    muni_boundary.boundary.plot(ax=ax, color=PALETTE["boundary"],
                                linewidth=lw, zorder=7)

    # Municipality name labels at each centroid
    if "name_muni" in muni_indiv.columns:
        for _, row in muni_indiv.iterrows():
            cx = row.geometry.centroid.x
            cy = row.geometry.centroid.y
            ax.text(
                cx, cy,
                row["name_muni"],
                fontsize=5.8, fontweight="bold",
                color=PALETTE["boundary"],
                ha="center", va="center",
                zorder=8,
                bbox=dict(facecolor="white", edgecolor="none",
                          alpha=0.60, boxstyle="round,pad=0.18"),
            )


def safe_choropleth(gdf, column, ax, cmap, title, unit_label=""):
    """
    Crash-proof choropleth masked to the exact municipal shape.

    Rendering order:
      1. Light-grey background (na_color)
      2. Thematic data (grid cells clipped to boundary)
      3. White inverse-mask  ← hides anything outside the boundary
      4. Boundary outline
      5. Axes extent locked to MAP_XLIM / MAP_YLIM
    """
    ax.set_facecolor(PALETTE["na_color"])

    col_data = (
        pd.to_numeric(gdf[column], errors="coerce")
        if column in gdf.columns
        else pd.Series(dtype=float)
    )
    valid = col_data.dropna()

    if valid.empty:
        gdf.plot(ax=ax, color=PALETTE["na_color"], linewidth=0)
        ax.text(0.5, 0.5, f"No data\n({column})",
                transform=ax.transAxes, ha="center", va="center",
                fontsize=8, color="#888888",
                bbox=dict(facecolor="white", edgecolor="none",
                          alpha=0.75, boxstyle="round,pad=0.4"))
    else:
        vmin, vmax = float(valid.min()), float(valid.max())
        if vmin == vmax:
            vmax = vmin + 1e-9

        plot_gdf = gdf.copy()
        plot_gdf["_v"] = col_data.values

        divider = make_axes_locatable(ax)
        cax = divider.append_axes("right", size="4%", pad=0.06)

        plot_gdf.plot(
            column="_v",
            ax=ax,
            cmap=cmap,
            linewidth=0,
            vmin=vmin,
            vmax=vmax,
            legend=True,
            legend_kwds={
                "cax":         cax,
                "orientation": "vertical",
                "shrink":      0.85,
                "pad":         0.02,
            },
            missing_kwds={"color": PALETTE["na_color"], "label": "No data"},
        )

        cax.tick_params(labelsize=6.5)
        if unit_label:
            cax.set_ylabel(unit_label, fontsize=6, labelpad=3)

    # 3. Mask outside boundary → 4. Outline → 5. Extent
    _apply_mask(ax)
    _draw_boundary(ax)
    _apply_map_extent(ax)

    ax.set_title(title, fontsize=9, fontweight="bold",
                 color=PALETTE["title_text"], pad=4)
    ax.set_axis_off()


def add_panel_label(ax, label):
