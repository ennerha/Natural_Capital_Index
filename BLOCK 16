    if row["converted_high_nci"]:
        return "Observed urban expansion in high-NCI cell"
    if row["robust_high_nci"] and row["floodplain_priority"]:
        return "Robust high-NCI floodplain priority"
    if row["robust_high_nci"]:
        return "Robust high-NCI conservation priority"
    if row[new_urban_col] > 0:
        return "Observed urban expansion"
    return "Other / lower priority"


