def overlay_boundary(ax, gdf):
    """Overlay municipal boundary on any map panel."""
    gdf.boundary.plot(ax=ax, edgecolor="black", linewidth=1.2, zorder=5)

def safe_choropleth(gdf, column, ax, cmap,
                    legend=True, vmin=None, vmax=None, norm=None):
    """Plot choropleth safely; grey panel if column missing or all-NaN."""
    if column not in gdf.columns or gdf[column].dropna().empty:
        gdf.plot(ax=ax, color="lightgrey", linewidth=0)
        ax.text(0.5, 0.5, f"No data\n({column})",
                transform=ax.transAxes, ha="center", va="center",
                fontsize=8, color="#666",
                bbox=dict(facecolor="white", alpha=0.7))
        return
    valid = gdf[column].dropna()
    vmin  = vmin if vmin is not None else float(valid.min())
    vmax  = vmax if vmax is not None else float(valid.max())
    kw = dict(column=column, ax=ax, legend=legend, cmap=cmap,
              linewidth=0.0, vmin=vmin, vmax=vmax,
              missing_kwds={"color": "lightgrey"})
    if norm is not None:
        kw["norm"] = norm; kw.pop("vmin"); kw.pop("vmax")
    gdf.plot(**kw)

