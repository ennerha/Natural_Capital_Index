            analysis_gdf[c] = pd.to_numeric(analysis_gdf[c], errors="coerce").fillna(0)

    native_col     = find_col(analysis_gdf, f"native_area_{year}",            must_contain="ha")
    edge_col       = find_col(analysis_gdf, f"native_edge_area_{year}",       must_contain="ha")
    core_col       = find_col(analysis_gdf, f"native_core_area_{year}",       must_contain="ha")
    connected_col  = find_col(analysis_gdf, f"connected_native_area_{year}",  must_contain="ha")
    fragmented_col = find_col(analysis_gdf, f"fragmented_native_area_{year}", must_contain="ha")
    density_col    = find_col(analysis_gdf, f"local_native_density_{year}")

    missing = [n for n, c in [("native", native_col), ("edge", edge_col),
                                ("core", core_col), ("connected", connected_col),
                                ("fragmented", fragmented_col)] if c is None]
    if missing:
        print(f"  WARNING year {year}: missing columns for {missing}")
    else:
        print(f"  Year {year}: all columns resolved OK")

    if native_col:
        analysis_gdf[f"native_fraction_{year}"] = (
            analysis_gdf[native_col] / analysis_gdf["grid_area_ha"]
        ).clip(0, 1)
    else:
        analysis_gdf[f"native_fraction_{year}"] = np.nan

    safe_fraction(analysis_gdf, edge_col,       native_col, f"edge_frac_of_native_{year}")
    safe_fraction(analysis_gdf, core_col,       native_col, f"core_frac_of_native_{year}")
    safe_fraction(analysis_gdf, connected_col,  native_col, f"connected_frac_of_native_{year}")
    safe_fraction(analysis_gdf, fragmented_col, native_col, f"fragmented_frac_of_native_{year}")

    if density_col:
        analysis_gdf[f"mean_local_density_{year}"] = pd.to_numeric(
            analysis_gdf[density_col], errors="coerce"
        )
    else:
        analysis_gdf[f"mean_local_density_{year}"] = np.nan

