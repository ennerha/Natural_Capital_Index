# 7. MapBiomas and native vegetation classes
# ------------------------------------------------------------

mapbiomas       = ee.Image(CONFIG["mapbiomas_asset"])
REFERENCE_YEARS = [1985, 2000, 2010, 2015, BASELINE_YEAR]
NATIVE_CLASSES  = [3, 4, 5, 6, 11, 12, 32, 49, 50]


def class_mask(img, classes):
    return img.remap(classes, [1] * len(classes), 0).eq(1)

# ------------------------------------------------------------
# 8. Build fragmentation indicator stack
# ------------------------------------------------------------

fragmentation_bands = []

for year in REFERENCE_YEARS:
    lulc   = clip_image_to_aoi(
        mapbiomas.select(f"classification_{year}"), aoi_geom
    )
    native = class_mask(lulc, NATIVE_CLASSES)

    native_area = area_band(native, f"native_area_{year}_ha")

    # Edge: native pixels with at least one non-native neighbour
    nbr_sum   = native.reduceNeighborhood(
        reducer=ee.Reducer.sum(),
        kernel=ee.Kernel.square(radius=1, units="pixels"),
        skipMasked=False
    )
    edge_native = native.And(nbr_sum.lt(9))
    edge_area   = area_band(edge_native, f"native_edge_area_{year}_ha")

    # Core: native pixels whose full 3×3 neighbourhood is native
    core_native = native.And(nbr_sum.eq(9))
    core_area   = area_band(core_native, f"native_core_area_{year}_ha")

    # Local native density within 300 m
    local_density = native.reduceNeighborhood(
        reducer=ee.Reducer.mean(),
        kernel=ee.Kernel.circle(radius=300, units="meters"),
        skipMasked=False
    ).rename(f"local_native_density_{year}")

    # Connected (density ≥ 0.5) and fragmented (density < 0.3)
    connected_area  = area_band(native.And(local_density.gte(0.5)),
                                f"connected_native_area_{year}_ha")
    fragmented_area = area_band(native.And(local_density.lt(0.3)),
                                f"fragmented_native_area_{year}_ha")

    fragmentation_bands += [
        native_area, edge_area, core_area,
        connected_area, fragmented_area, local_density
    ]

fragmentation_stack = fragmentation_bands[0]
for b in fragmentation_bands[1:]:
    fragmentation_stack = fragmentation_stack.addBands(b)

