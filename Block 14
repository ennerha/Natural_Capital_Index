# ------------------------------------------------------------
# 6. Helper functions
# ------------------------------------------------------------

def clip_image_to_aoi(image: ee.Image, geom: ee.Geometry) -> ee.Image:
    return (image.clip(geom)
            .updateMask(ee.Image.constant(1).clip(geom).unmask(0)))


def area_band(mask: ee.Image, name: str) -> ee.Image:
    return ee.Image.pixelArea().divide(1e4).updateMask(mask).rename(name)


def find_col(df, prefix, must_contain=None):
    for c in df.columns:
        if c.startswith(prefix):
            if must_contain is None or must_contain in c:
                return c
    return None


def safe_fraction(df, num_col, den_col, out_name):
    if num_col is None or den_col is None or den_col not in df.columns:
        df[out_name] = np.nan
        return
    df[out_name] = np.where(df[den_col] > 0,
                             df[num_col] / df[den_col],
                             np.nan)


def md5_checksum(fp: Path) -> str:
    h = hashlib.md5()
    with open(fp, "rb") as f:
        for chunk in iter(lambda: f.read(8192), b""):
            h.update(chunk)
    return h.hexdigest()

