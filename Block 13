    ax_e.plot(xl, coef[0] * xl + coef[1], "k-", linewidth=1.5)
    corr = float(valid[["floodplain_fraction", "NCI_BR"]].corr().iloc[0, 1])
    ax_e.text(0.97, 0.95, f"r = {corr:.3f}", transform=ax_e.transAxes,
