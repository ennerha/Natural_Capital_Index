# ------------------------------------------------------------
# 5. Helper functions
# ------------------------------------------------------------

def clip_image_to_aoi(image: ee.Image, geom: ee.Geometry) -> ee.Image:
    return (image.clip(geom)
            .updateMask(ee.Image.constant(1).clip(geom).unmask(0)))


def area_band(mask: ee.Image, name: str) -> ee.Image:
    return ee.Image.pixelArea().divide(1e4).updateMask(mask).rename(name)


def find_col(df, candidates, required=True):
    for c in candidates:
        if c in df.columns:
            return c
    if required:
        raise ValueError(f"None of these columns found: {candidates}")
    return None


def md5_checksum(fp: Path) -> str:
    h = hashlib.md5()
    with open(fp, "rb") as f:
        for chunk in iter(lambda: f.read(8192), b""):
            h.update(chunk)
    return h.hexdigest()

# ------------------------------------------------------------
# 6. Load observed conversion and clip to real SJC polygon
# ------------------------------------------------------------

CANDIDATE_INPUTS = [
    DIRS["processed"] / "nci_br_sjc_evidence_synthesis.gpkg",
    DIRS["processed"] / "nci_br_sjc_observed_conversion.gpkg",
    DIRS["processed"] / "nci_br_real_data_evidence_synthesis_map.gpkg",
    DIRS["processed"] / "nci_br_observed_urban_conversion_accounting.gpkg",
]
input_path = next((p for p in CANDIDATE_INPUTS if p.exists()), None)
if input_path is None:
    raise FileNotFoundError(
        "No observed conversion dataset found. Tried:\n" +
        "\n".join(f"  {p}" for p in CANDIDATE_INPUTS)
    )
print(f"\nUsing input: {input_path.name}")

gdf = gpd.read_file(input_path)
if gdf.crs is None:
    gdf = gdf.set_crs(plot_crs)
gdf = gdf.to_crs(plot_crs)

# Clip to real SJC polygon — same pattern as Block 03
