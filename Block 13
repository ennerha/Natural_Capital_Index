gdf = gpd.clip(gdf, muni_plot).copy().reset_index(drop=True)
print(f"Clip to SJC  : {n_before} → {len(gdf)} cells "
      f"({n_before - len(gdf)} outside SJC removed)")

# Guard grid_area_ha
if "grid_area_ha" not in gdf.columns or gdf["grid_area_ha"].isna().all():
    gdf["grid_area_ha"] = gdf.geometry.area / 1e4
else:
    gdf["grid_area_ha"] = pd.to_numeric(gdf["grid_area_ha"], errors="coerce")
    bad = gdf["grid_area_ha"].isna() | (gdf["grid_area_ha"] <= 0)
    if bad.any():
        gdf.loc[bad, "grid_area_ha"] = gdf.loc[bad].geometry.area / 1e4

print(f"Observed cells: {len(gdf)}")

# Detect response columns
urban_col = find_col(gdf, [
    f"new_urban_{REF_YEAR}_{TARGET_YEAR}_ha",
    f"observed_new_urban_{REF_YEAR}_{TARGET_YEAR}_ha",
])
native_col = find_col(gdf, [f"native_to_urban_{REF_YEAR}_{TARGET_YEAR}_ha"])

for col in [urban_col, native_col, "NCI_BR", "grid_area_ha"]:
    gdf[col] = pd.to_numeric(gdf[col], errors="coerce").fillna(0)

print(f"Urban column : {urban_col}")
print(f"Native column: {native_col}")

# ------------------------------------------------------------
# 7. Load SJC grid and clip to municipality
# ------------------------------------------------------------

CANDIDATE_GRIDS = [
    DIRS["processed"] / "nci_br_sjc_grid_1km.gpkg",
    DIRS["processed"] / "nci_br_pilot_grid_1km.gpkg",
]
grid_path = next((p for p in CANDIDATE_GRIDS if p.exists()), None)
if grid_path is None:
    raise FileNotFoundError("Grid file not found. Run Block 02 first.")

grid_gdf = gpd.read_file(grid_path)
if grid_gdf.crs is None:
    grid_gdf = grid_gdf.set_crs(plot_crs)
grid_gdf = grid_gdf.to_crs(plot_crs)

# Clip grid to real SJC polygon
grid_gdf = gpd.clip(grid_gdf, muni_plot).reset_index(drop=True)
grid_ee  = geemap.geopandas_to_ee(grid_gdf.to_crs("EPSG:4326"))
print(f"Grid cells (SJC only): {len(grid_gdf)}")

# ------------------------------------------------------------
# 8. MERIT Hydro HAND — clipped to real SJC boundary
# ------------------------------------------------------------

hand = clip_image_to_aoi(
    ee.Image("MERIT/Hydro/v1_0_1").select("hnd"), aoi_geom
)

fp_lte5  = hand.lte(5)
fp_5_10  = hand.gt(5).And(hand.lte(10))
fp_10_20 = hand.gt(10).And(hand.lte(20))
upland   = hand.gt(20)
fp_total = hand.lte(10)   # main floodplain definition

hand_stack = ee.Image.cat([
    hand.rename("HAND"),
    area_band(fp_lte5,  "fp_0_5_ha"),
    area_band(fp_5_10,  "fp_5_10_ha"),
    area_band(fp_10_20, "fp_10_20_ha"),
    area_band(upland,   "upland_gt20_ha"),
    area_band(fp_total, "fp_total_ha"),
])

# ------------------------------------------------------------
# 9. Extract HAND metrics per 1-km grid cell
# ------------------------------------------------------------

print("\nExtracting HAND and floodplain metrics per 1-km cell...")

hand_fc  = hand_stack.reduceRegions(
    collection=grid_ee,
    reducer=ee.Reducer.mean().combine(ee.Reducer.sum(), sharedInputs=True),
    scale=90,
    tileScale=4
)

hand_gdf = geemap.ee_to_gdf(hand_fc)
if hand_gdf.crs is None:
    hand_gdf = hand_gdf.set_crs("EPSG:4326")

if "grid_id" not in hand_gdf.columns:
    hand_gdf["grid_id"] = hand_gdf.index.astype(int)

# ------------------------------------------------------------
# 10. Merge HAND metrics with observed conversion
# ------------------------------------------------------------

hand_table   = pd.DataFrame(hand_gdf.drop(columns="geometry", errors="ignore"))
analysis_gdf = gdf.merge(hand_table, on="grid_id", how="left", suffixes=("", "_hand"))

# Resolve HAND column names
hand_col     = find_col(analysis_gdf, ["HAND_mean", "HAND", "hnd_mean"])
fp_total_col = find_col(analysis_gdf, ["fp_total_ha_sum",   "fp_total_ha",   "fp_total_ha_mean"])
fp_0_5_col   = find_col(analysis_gdf, ["fp_0_5_ha_sum",     "fp_0_5_ha",     "fp_0_5_ha_mean"])
fp_5_10_col  = find_col(analysis_gdf, ["fp_5_10_ha_sum",    "fp_5_10_ha",    "fp_5_10_ha_mean"])
fp_10_20_col = find_col(analysis_gdf, ["fp_10_20_ha_sum",   "fp_10_20_ha",   "fp_10_20_ha_mean"])
upland_col   = find_col(analysis_gdf, ["upland_gt20_ha_sum","upland_gt20_ha","upland_gt20_ha_mean"])

print(f"\nHAND columns resolved:")
for lbl, col in [("HAND",      hand_col), ("FP total", fp_total_col),
                  ("FP 0–5",   fp_0_5_col), ("FP 5–10", fp_5_10_col),
                  ("FP 10–20", fp_10_20_col), (">20 m",  upland_col)]:
    print(f"  {lbl:<10}: {col}")

for col in [hand_col, fp_total_col, fp_0_5_col, fp_5_10_col, fp_10_20_col, upland_col]:
    analysis_gdf[col] = pd.to_numeric(analysis_gdf[col], errors="coerce").fillna(0)

# ------------------------------------------------------------
# 11. Floodplain occupation indicators
# ------------------------------------------------------------

analysis_gdf["floodplain_fraction"] = (
    analysis_gdf[fp_total_col] / analysis_gdf["grid_area_ha"]
).clip(0, 1)

analysis_gdf["urban_in_fp_ha"]  = analysis_gdf[urban_col]  * analysis_gdf["floodplain_fraction"]
analysis_gdf["native_in_fp_ha"] = analysis_gdf[native_col] * analysis_gdf["floodplain_fraction"]
analysis_gdf["NCI_exp_in_fp"]   = analysis_gdf["urban_in_fp_ha"] * analysis_gdf["NCI_BR"]

# Floodplain exposure class
CLASS_ORDER = ["Very high (≥75 %)", "High (50–75 %)", "Moderate (25–50 %)", "Low (<25 %)"]
CLASS_COLORS = {
    "Very high (≥75 %)": "#08306b",
    "High (50–75 %)":    "#2171b5",
    "Moderate (25–50 %)":"#6baed6",
    "Low (<25 %)":       "#deebf7",
}

def classify_fp(frac):
    if frac >= 0.75: return "Very high (≥75 %)"
    if frac >= 0.50: return "High (50–75 %)"
    if frac >= 0.25: return "Moderate (25–50 %)"
    return "Low (<25 %)"

analysis_gdf["fp_class"] = analysis_gdf["floodplain_fraction"].apply(classify_fp)

# ------------------------------------------------------------
# 12. Summary statistics
# ------------------------------------------------------------

tot_urban  = float(analysis_gdf[urban_col].sum())
tot_native = float(analysis_gdf[native_col].sum())
tot_urb_fp = float(analysis_gdf["urban_in_fp_ha"].sum())
tot_nat_fp = float(analysis_gdf["native_in_fp_ha"].sum())
tot_nci_fp = float(analysis_gdf["NCI_exp_in_fp"].sum())
mean_nci_fp50 = float(analysis_gdf.loc[analysis_gdf["floodplain_fraction"] >= 0.5, "NCI_BR"].mean())

summary_df = pd.DataFrame([
    ("Urban conversion inside floodplain (HAND ≤ 10 m)", tot_urb_fp, "ha"),
    ("Native-to-urban conversion inside floodplain",      tot_nat_fp, "ha"),
    ("% urban conversion inside floodplain",
     tot_urb_fp / tot_urban * 100 if tot_urban > 0 else np.nan, "%"),
    ("% native conversion inside floodplain",
     tot_nat_fp / tot_native * 100 if tot_native > 0 else np.nan, "%"),
    ("Area-weighted NCI exposure inside floodplain",      tot_nci_fp, "NCI × ha"),
    ("Mean NCI-BR in high-floodplain cells (≥50 %)",      mean_nci_fp50, "0–100"),
], columns=["metric", "value", "unit"])

grouped_df = (
    analysis_gdf.groupby("fp_class")
    .agg(
        n_cells=("grid_id",             "count"),
        mean_NCI_BR=("NCI_BR",           "mean"),
        mean_fp_frac=("floodplain_fraction","mean"),
        urban_conv_ha=(urban_col,         "sum"),
        native_conv_ha=(native_col,       "sum"),
        urban_in_fp_ha=("urban_in_fp_ha", "sum"),
        NCI_exp_in_fp=("NCI_exp_in_fp",   "sum"),
        mean_HAND=(hand_col,              "mean"),
    )
    .reset_index()
    .sort_values("mean_fp_frac", ascending=False)
