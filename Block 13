        cell.set_facecolor("#f0f0f0"); cell.set_text_props(weight="bold")
ax_f.set_title("Floodplain occupation summary", loc="left")
add_panel_label(ax_f, "f")

# ── Panel g — HAND histogram ──────────────────────────────────
hand_vals = pd.to_numeric(analysis_gdf[hand_col], errors="coerce").dropna()
if len(hand_vals) > 0:
    ax_g.hist(hand_vals, bins=50, color="#2171b5",
              edgecolor="white", linewidth=0.3, alpha=0.85)
    ax_g.axvline(5,  color="#d62728", linewidth=1.2, linestyle="--", label="5 m")
    ax_g.axvline(10, color="#fdae6b", linewidth=1.2, linestyle=":",  label="10 m")
    ax_g.axvline(float(hand_vals.median()), color="black", linewidth=1.0,
