xbuf = (xmax - xmin) * 0.05
ybuf = (ymax - ymin) * 0.05
map_extent = [xmin - xbuf, xmax + xbuf, ymin - ybuf, ymax + ybuf]

print(f"Municipality : {MUNICIPALITY}")
print(f"Map extent   : {xmin:.0f}, {ymin:.0f} → {xmax:.0f}, {ymax:.0f} (EPSG:5880)")

# ------------------------------------------------------------
# 5. Load regression input data and clip to real SJC polygon
# ------------------------------------------------------------

CANDIDATE_INPUTS = [
    DIRS["processed"] / "nci_br_sjc_evidence_synthesis.gpkg",
    DIRS["processed"] / "nci_br_sjc_observed_conversion.gpkg",
    DIRS["processed"] / "nci_br_real_data_evidence_synthesis_map.gpkg",
    DIRS["processed"] / "nci_br_observed_urban_conversion_accounting.gpkg",
]

input_path = next((p for p in CANDIDATE_INPUTS if p.exists()), None)
if input_path is None:
    raise FileNotFoundError(
        "No observed conversion dataset found. Tried:\n" +
        "\n".join(f"  {p}" for p in CANDIDATE_INPUTS)
    )
print(f"\nUsing input: {input_path.name}")

gdf = gpd.read_file(input_path)
if gdf.crs is None:
    gdf = gdf.set_crs(plot_crs)
gdf = gdf.to_crs(plot_crs)

# Clip to real SJC polygon — same way Block 03 clips GEE outputs to aoi_geom
n_before = len(gdf)
gdf = gpd.clip(gdf, muni_plot).copy().reset_index(drop=True)
print(f"Clip to SJC  : {n_before} → {len(gdf)} cells "
      f"({n_before - len(gdf)} outside SJC removed)")

# ------------------------------------------------------------
# 6. Detect response and predictor columns
# ------------------------------------------------------------

def find_column(df, candidates, required=True):
    for c in candidates:
        if c in df.columns:
            return c
    if required:
        raise ValueError(f"None of the candidate columns found: {candidates}")
    return None

response_col = find_column(gdf, [
    f"new_urban_{REF_YEAR}_{TARGET_YEAR}_ha",
    f"observed_new_urban_{REF_YEAR}_{TARGET_YEAR}_ha",
])
native_col = find_column(gdf, [
    f"native_to_urban_{REF_YEAR}_{TARGET_YEAR}_ha",
], required=False)

gdf[response_col] = pd.to_numeric(gdf[response_col], errors="coerce").fillna(0)
if native_col:
    gdf[native_col] = pd.to_numeric(gdf[native_col], errors="coerce").fillna(0)

gdf["y_obs_urban_ha"] = gdf[response_col]
gdf["y_log1p_urban"]  = np.log1p(gdf["y_obs_urban_ha"])

CANDIDATE_PREDICTORS = [
    "NCI_BR",
    "score_native_vegetation",
    "score_vegetation_condition",
    "score_hydrological_regulation",
    "score_low_anthropic_pressure",
    "score_floodplain_function",
    "score_vegetation_trend",
]

available_predictors = [c for c in CANDIDATE_PREDICTORS if c in gdf.columns]

# If NCI scores are missing, merge from Block 06
if len(available_predictors) < 3:
    nci_fb_paths = [
        DIRS["processed"] / "nci_br_sjc_grid_integrated_index.gpkg",
        DIRS["processed"] / "nci_br_grid_integrated_index.gpkg",
        DIRS["processed"] / "nci_br_sjc_spatial_statistics.gpkg",
        DIRS["processed"] / "nci_br_spatial_statistics_lisa_hotspots.gpkg",
    ]
    nci_fb = next((p for p in nci_fb_paths if p.exists()), None)
    if nci_fb:
        print(f"  Merging NCI scores from: {nci_fb.name}")
        nci_merge = gpd.read_file(nci_fb)
        score_cols = [c for c in CANDIDATE_PREDICTORS if c in nci_merge.columns]
        if "grid_id" in nci_merge.columns and score_cols:
            if "grid_id" not in gdf.columns:
                gdf["grid_id"] = gdf.index.astype(int)
            gdf = gdf.merge(
                pd.DataFrame(nci_merge[["grid_id"] + score_cols]),
                on="grid_id", how="left", suffixes=("", "_nci")
            )
            available_predictors = [c for c in CANDIDATE_PREDICTORS if c in gdf.columns]
            print(f"  After merge: {len(available_predictors)} predictors available")

if len(available_predictors) < 3:
    raise ValueError(
        f"Too few predictors ({len(available_predictors)}): {available_predictors}\n"
        "Run Block 06 first."
    )

for col in available_predictors:
    gdf[col] = pd.to_numeric(gdf[col], errors="coerce")

model_gdf = gdf.dropna(
    subset=["y_log1p_urban"] + available_predictors
).reset_index(drop=True).copy()

# Project to plot_crs for mapping — same as Block 03's grid_lulc_plot
model_plot = model_gdf.to_crs(plot_crs) if model_gdf.crs != plot_crs else model_gdf.copy()

print(f"\nValid cells for regression : {len(model_gdf)}")
print(f"Response column           : {response_col}")
print(f"Predictors ({len(available_predictors)})           : {available_predictors}")

# ------------------------------------------------------------
# 7. Spatial weights
# ------------------------------------------------------------

def build_weights(gdf):
    try:
        w = Queen.from_dataframe(gdf)
        if len(w.islands) > 0:
            w = KNN.from_dataframe(gdf, k=8)
            wtype = "KNN-8"
        else:
            wtype = "Queen contiguity"
    except Exception as e:
        print(f"  Queen failed ({e}). Using KNN-8.")
        w = KNN.from_dataframe(gdf, k=8)
        wtype = "KNN-8"
    w.transform = "r"
    return w, wtype

w, weights_type = build_weights(model_gdf)
print(f"Spatial weights: {weights_type}")

# ------------------------------------------------------------
# 8. Standardize predictors and fit OLS
# ------------------------------------------------------------

X_raw    = model_gdf[available_predictors].copy()
scaler   = StandardScaler()
X_scaled = scaler.fit_transform(X_raw)
z_names  = [f"z_{c}" for c in available_predictors]
X_scaled_df = pd.DataFrame(X_scaled, columns=z_names, index=model_gdf.index)
for col in z_names:
    model_gdf[col] = X_scaled_df[col]

X_sm   = sm.add_constant(X_scaled_df)
ols_sm = sm.OLS(model_gdf["y_log1p_urban"], X_sm).fit(cov_type="HC3")

model_gdf["OLS_resid"]     = ols_sm.resid
model_gdf["OLS_predicted"] = ols_sm.predict(X_sm)
model_gdf["OLS_pred_ha"]   = np.expm1(model_gdf["OLS_predicted"]).clip(lower=0)
model_gdf["OLS_resid_lag"] = lag_spatial(w, model_gdf["OLS_resid"].values)

resid_moran = Moran(model_gdf["OLS_resid"].values, w, permutations=999)
print(f"\nOLS R²           : {ols_sm.rsquared:.4f}")
print(f"OLS AIC          : {ols_sm.aic:.2f}")
print(f"Resid. Moran I   : {resid_moran.I:.4f} (p = {resid_moran.p_sim:.4f})")

# ------------------------------------------------------------
# 9. Spatial regression models
# ------------------------------------------------------------

Y = model_gdf["y_log1p_urban"].values.reshape(-1, 1)
X = model_gdf[z_names].values

def safe_get(obj, attr, idx=None, default=np.nan):
    val = getattr(obj, attr, None)
    if val is None: return default
    try: return float(val[idx]) if idx is not None else float(val)
    except: return default

sp_ols = OLS(Y, X, w=w, name_y="log1p_urban_ha", name_x=z_names,
             name_w=weights_type, spat_diag=True, moran=True)

lag_model, lag_ok = None, False
try:
    lag_model = ML_Lag(Y, X, w=w, name_y="log1p_urban_ha",
                       name_x=z_names, name_w=weights_type, method="ord")
    lag_ok = True
    model_gdf["Lag_predicted"] = lag_model.predy.flatten()
    model_gdf["Lag_pred_ha"]   = np.expm1(model_gdf["Lag_predicted"]).clip(lower=0)
    print(f"Spatial Lag AIC  : {lag_model.aic:.2f}")
except Exception as e:
    print(f"Spatial lag failed: {e}")

error_model, error_ok = None, False
try:
    error_model = ML_Error(Y, X, w=w, name_y="log1p_urban_ha",
                           name_x=z_names, name_w=weights_type, method="ord")
    error_ok = True
    print(f"Spatial Error AIC: {error_model.aic:.2f}")
except Exception as e:
    print(f"Spatial error failed: {e}")

# ------------------------------------------------------------
# 10. Model comparison and coefficient tables
# ------------------------------------------------------------

model_records = [
    {"model": "OLS HC3", "n": int(ols_sm.nobs),
     "r2": round(ols_sm.rsquared, 4), "aic": round(ols_sm.aic, 2),
     "resid_moran_I": round(resid_moran.I, 4),
     "resid_moran_p": round(resid_moran.p_sim, 4)},
]
if lag_ok:
    model_records.append({
        "model": "Spatial Lag ML", "n": lag_model.n,
        "r2": round(safe_get(lag_model, "pr2"), 4),
        "aic": round(lag_model.aic, 2),
        "resid_moran_I": np.nan, "resid_moran_p": np.nan})
if error_ok:
    model_records.append({
        "model": "Spatial Error ML", "n": error_model.n,
        "r2": round(safe_get(error_model, "pr2"), 4),
        "aic": round(error_model.aic, 2),
        "resid_moran_I": np.nan, "resid_moran_p": np.nan})

model_comparison = pd.DataFrame(model_records)
best_aic = model_comparison.loc[model_comparison["aic"].idxmin(), "model"]
print(f"Best AIC model   : {best_aic}")

ols_coef_df = pd.DataFrame({
    "model":    "OLS_HC3",
    "variable": ols_sm.params.index,
    "coef":     ols_sm.params.values,
    "std_err":  ols_sm.bse.values,
    "t_stat":   ols_sm.tvalues.values,
    "p_value":  ols_sm.pvalues.values,
})

interp_records = []
for pred, zname in zip(available_predictors, z_names):
    row = ols_coef_df[ols_coef_df["variable"] == zname]
    if len(row) == 0: continue
    coef = float(row["coef"].iloc[0])
    pval = float(row["p_value"].iloc[0])
    interp_records.append({
        "predictor":    pred,
        "std_coef_OLS": round(coef, 4),
        "p_value":      round(pval, 4),
        "direction":    "positive" if coef > 0 else "negative",
        "significance": ("significant"    if pval <= 0.05 else
                         "marginal"        if pval <= 0.10 else
                         "not significant"),
    })
interpretation_df = pd.DataFrame(interp_records)

# ------------------------------------------------------------
# 11. Export products
# ------------------------------------------------------------

reg_gpkg_path = DIRS["processed"] / "nci_br_sjc_spatial_regression.gpkg"
comp_path     = DIRS["tables"]    / "nci_br_sjc_spatial_regression_model_comparison.csv"
coef_path     = DIRS["tables"]    / "nci_br_sjc_spatial_regression_coefficients.csv"
interp_path   = DIRS["tables"]    / "nci_br_sjc_spatial_regression_interpretation.csv"

model_gdf.to_file(reg_gpkg_path, layer="spatial_regression", driver="GPKG")
model_comparison.to_csv(comp_path,        index=False, encoding="utf-8-sig")
ols_coef_df.to_csv(coef_path,             index=False, encoding="utf-8-sig")
interpretation_df.to_csv(interp_path,     index=False, encoding="utf-8-sig")

print(f"\nOutputs exported:")
for p in [reg_gpkg_path, comp_path, coef_path, interp_path]:
    print(f"  {p}")
logger.info(f"Outputs exported. n={len(model_gdf)} | weights={weights_type}")

# ------------------------------------------------------------
# 12. Cartographic helpers — IDENTICAL to Block 03
# ------------------------------------------------------------

def add_panel_label(ax, label):
    ax.text(0.02, 0.97, label, transform=ax.transAxes,
            fontsize=12, fontweight="bold", va="top", ha="left",
            bbox=dict(facecolor="white", edgecolor="none",
                      alpha=0.88, boxstyle="round,pad=0.22"))

def overlay_boundary(ax, gdf):
    """Overlay municipal boundary on any map panel."""
    gdf.boundary.plot(ax=ax, edgecolor="black", linewidth=1.2, zorder=5)

# Update model_plot after model_gdf was finalized
model_plot = model_gdf.to_crs(plot_crs)

