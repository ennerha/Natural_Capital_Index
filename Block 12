muni_path = DIRS["processed"] / "nci_br_sjc_municipality.gpkg"

if not muni_path.exists():
    print("nci_br_sjc_municipality.gpkg not found.")
    print("Downloading real SJC boundary from IBGE API (code 3549904)...")
    url = ("https://servicodados.ibge.gov.br/api/v3/malhas/municipios"
           "/3549904?formato=application/json&qualidade=maxima")
    resp = requests.get(url, timeout=30)
    resp.raise_for_status()
    muni_gdf = gpd.read_file(io.BytesIO(resp.content))
    muni_gdf = muni_gdf.set_crs("EPSG:4326").to_crs("EPSG:4674")
    muni_gdf["NM_MUN"]   = MUNICIPALITY
    muni_gdf["CD_MUN"]   = "3549904"
    muni_gdf["SIGLA_UF"] = "SP"
    muni_gdf.to_file(muni_path, driver="GPKG")
    print(f"  Saved to: {muni_path.name}")
else:
    muni_gdf = gpd.read_file(muni_path)
    print(f"Municipal boundary loaded: {muni_path.name}")

# From here: identical to Block 03
