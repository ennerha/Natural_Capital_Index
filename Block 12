logger.info(f"Block 12 started — {MUNICIPALITY}.")
print(f"Log file: {log_file}")

# ------------------------------------------------------------
# 4. Load municipality boundary — EXACT SAME PATTERN AS BLOCK 03
#
#    Block 03 section 4:
#        muni_path = DIRS["processed"] / "nci_br_sjc_municipality.gpkg"
#        muni_gdf  = gpd.read_file(muni_path)
#        if muni_gdf.crs is None:
