overlay_boundary(ax_a, muni_plot)
ax_a.set_xlim(map_extent[0], map_extent[1])
ax_a.set_ylim(map_extent[2], map_extent[3])
ax_a.set_title(f"Observed conversion {REF_YEAR}–{TARGET_YEAR}", loc="left")
ax_a.set_axis_off()
add_panel_label(ax_a, "a")

# ── Panel b — OLS predicted map ───────────────────────────────
model_plot.plot(
    column="OLS_pred_ha", ax=ax_b,
    cmap="Reds", linewidth=0.0, legend=True,
    legend_kwds={"label": "OLS-predicted (ha)", "shrink": 0.7},
    missing_kwds={"color": "lightgrey"}
)
overlay_boundary(ax_b, muni_plot)
ax_b.set_xlim(map_extent[0], map_extent[1])
ax_b.set_ylim(map_extent[2], map_extent[3])
ax_b.set_title("OLS-predicted conversion (back-transformed)", loc="left")
ax_b.set_axis_off()
add_panel_label(ax_b, "b")

# ── Panel c — Model comparison table ─────────────────────────
ax_c.axis("off")
mc_disp = model_comparison.copy()
for col in ["r2", "aic", "resid_moran_I", "resid_moran_p"]:
    mc_disp[col] = mc_disp[col].map(lambda x: f"{x:.3f}" if pd.notna(x) else "—")
tbl = ax_c.table(
    cellText=mc_disp[["model", "r2", "aic", "resid_moran_I", "resid_moran_p"]].values,
    colLabels=["Model", "R²", "AIC", "Moran I (res)", "p"],
    loc="center", cellLoc="center"
)
tbl.auto_set_font_size(False); tbl.set_fontsize(6.8); tbl.scale(1.0, 1.35)
for (row, col), cell in tbl.get_celld().items():
    cell.set_edgecolor("#bdbdbd"); cell.set_linewidth(0.5)
    if row == 0:
        cell.set_facecolor("#f0f0f0"); cell.set_text_props(weight="bold")
ax_c.set_title("Model comparison (lower AIC = better)", loc="left")
add_panel_label(ax_c, "c")

# ── Panel d — OLS residual map ────────────────────────────────
resid_vals = model_plot["OLS_resid"].dropna()
if len(resid_vals) > 0:
    vmax_abs = max(abs(float(resid_vals.quantile(0.02))),
                   abs(float(resid_vals.quantile(0.98))), 0.01)
    norm_div = TwoSlopeNorm(vmin=-vmax_abs, vcenter=0, vmax=vmax_abs)
    model_plot.plot(
        column="OLS_resid", ax=ax_d,
        cmap="RdBu_r", norm=norm_div, linewidth=0.0, legend=True,
        legend_kwds={"label": "OLS residual", "shrink": 0.7},
        missing_kwds={"color": "lightgrey"}
    )
overlay_boundary(ax_d, muni_plot)
ax_d.set_xlim(map_extent[0], map_extent[1])
ax_d.set_ylim(map_extent[2], map_extent[3])
ax_d.set_title(
    f"OLS residuals (Moran I = {resid_moran.I:.3f}, p = {resid_moran.p_sim:.3f})",
    loc="left"
)
ax_d.set_axis_off()
add_panel_label(ax_d, "d")

# ── Panel e — Standardised OLS coefficients ──────────────────
coef_plot = ols_coef_df[ols_coef_df["variable"].isin(z_names)].copy()
coef_plot["label"] = (coef_plot["variable"]
                      .str.replace("z_score_", "", regex=False)
                      .str.replace("z_", "", regex=False)
                      .str.replace("_", " ").str[:22])
coef_plot["sig"]   = coef_plot["p_value"] <= 0.05
coef_plot = coef_plot.sort_values("coef")
colors_e  = ["#1a7a3c" if s else "#969696" for s in coef_plot["sig"]]
ax_e.barh(coef_plot["label"], coef_plot["coef"],
          color=colors_e, edgecolor="white", linewidth=0.4)
ax_e.axvline(0, color="black", linewidth=0.8)
ax_e.set_xlabel("Standardised OLS coefficient")
ax_e.set_title("OLS coefficients (green = p ≤ 0.05)", loc="left")
ax_e.tick_params(axis="y", labelsize=7.5)
ax_e.grid(axis="x", linewidth=0.3, alpha=0.5)
add_panel_label(ax_e, "e")

# ── Panel f — Interpretation table ───────────────────────────
ax_f.axis("off")
int_disp = interpretation_df.copy()
int_disp["predictor"]   = int_disp["predictor"].str.replace("score_", "", regex=False)
int_disp["std_coef_OLS"]= int_disp["std_coef_OLS"].map(lambda x: f"{x:.3f}")
