def check_column(
    dataset_name: str,
    df,
    candidates: list,
    expected_min=None,
    expected_max=None,
) -> None:
    col = find_column(df, candidates)
    record = {
        "dataset":        dataset_name,
        "candidates":     " | ".join(candidates),
        "resolved_column":col,
        "exists":         col is not None,
        "n_non_null":     np.nan,
        "n_null":         np.nan,
        "val_min":        np.nan,
        "val_max":        np.nan,
        "expected_range": f"{expected_min} to {expected_max}",
        "range_pass":     False,
    }
    if col is not None and df is not None:
        values = pd.to_numeric(df[col], errors="coerce")
        vmin, vmax = float(values.min()), float(values.max())
        range_ok = True
        if expected_min is not None:
            range_ok = range_ok and (vmin >= expected_min or np.isnan(vmin))
        if expected_max is not None:
            range_ok = range_ok and (vmax <= expected_max or np.isnan(vmax))
        record.update({
            "n_non_null":  int(values.notna().sum()),
            "n_null":      int(values.isna().sum()),
            "val_min":     round(vmin, 4),
            "val_max":     round(vmax, 4),
            "range_pass":  range_ok,
        })
    attribute_records.append(record)


