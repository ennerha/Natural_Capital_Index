# ------------------------------------------------------------
# 5. [FIX-11] Ensure grid_id present before merge
# ------------------------------------------------------------

def ensure_grid_id(gdf: gpd.GeoDataFrame, label: str) -> gpd.GeoDataFrame:
    if "grid_id" not in gdf.columns:
        print(f"  WARNING: grid_id missing from {label}. Using index.")
        gdf = gdf.copy()
        gdf["grid_id"] = gdf.index.astype(int)
    return gdf

grid_gdf = ensure_grid_id(grid_gdf, "grid")
nci_gdf  = ensure_grid_id(nci_gdf,  "NCI-BR")

# ------------------------------------------------------------
# 6. MapBiomas and analysis parameters
# ------------------------------------------------------------

mapbiomas     = ee.Image(CONFIG["mapbiomas_asset"])
TARGET_YEAR   = int(CONFIG["baseline_year"])
REFERENCE_YEARS = [1985, 2000, 2010, 2015]
START_YEAR    = 1985

URBAN_CLASS       = 24
NATIVE_CLASSES    = [3, 4, 5, 6, 11, 12, 32, 49, 50]
AGRI_CLASSES      = [15, 18, 19, 20, 39, 40, 41, 46, 47, 48]
WATER_CLASSES     = [33]
MINING_CLASSES    = [30]

print(f"\nObserved conversion: {START_YEAR}–{TARGET_YEAR}")
print(f"Reference years    : {REFERENCE_YEARS}")

# ------------------------------------------------------------
# 7. Helper functions
# ------------------------------------------------------------

def clip_image_to_aoi(image: ee.Image, aoi_geometry: ee.Geometry) -> ee.Image:
    """Clip and mask ee.Image to the exact municipal boundary."""
    return (
        image
        .clip(aoi_geometry)
        .updateMask(ee.Image.constant(1).clip(aoi_geometry).unmask(0))
    )


def class_mask(img: ee.Image, classes: list) -> ee.Image:
    return img.remap(classes, [1] * len(classes), 0).eq(1)


def area_band(mask: ee.Image, name: str) -> ee.Image:
    return ee.Image.pixelArea().divide(1e4).updateMask(mask).rename(name)


def safe_numeric(df: pd.DataFrame, cols: list) -> pd.DataFrame:
    for col in cols:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors="coerce").fillna(0)
    return df

# ------------------------------------------------------------
# 8. Build observed conversion stack
# ------------------------------------------------------------

# [FIX-12] Use TARGET_YEAR variable in band name (not hardcoded _2024)
lulc_target    = clip_image_to_aoi(
    mapbiomas.select(f"classification_{TARGET_YEAR}"), aoi_geom
)
urban_target   = lulc_target.eq(URBAN_CLASS)   # [FIX-12] renamed

conversion_bands = [
    area_band(urban_target, f"urban_{TARGET_YEAR}_ha")
]

for ref_year in REFERENCE_YEARS:
    lulc_ref     = clip_image_to_aoi(
        mapbiomas.select(f"classification_{ref_year}"), aoi_geom
    )   # [FIX-8]
    urban_ref    = lulc_ref.eq(URBAN_CLASS)
    new_urban    = urban_target.And(urban_ref.Not())  # net new urban since ref_year

    native_ref   = class_mask(lulc_ref, NATIVE_CLASSES)
    agri_ref     = class_mask(lulc_ref, AGRI_CLASSES)
    water_ref    = class_mask(lulc_ref, WATER_CLASSES)
    mining_ref   = class_mask(lulc_ref, MINING_CLASSES)

    conversion_bands += [
        area_band(new_urban,                     f"new_urban_{ref_year}_{TARGET_YEAR}_ha"),
        area_band(new_urban.And(native_ref),     f"native_to_urban_{ref_year}_{TARGET_YEAR}_ha"),
        area_band(new_urban.And(agri_ref),       f"agri_to_urban_{ref_year}_{TARGET_YEAR}_ha"),
        area_band(new_urban.And(water_ref),      f"water_to_urban_{ref_year}_{TARGET_YEAR}_ha"),
        area_band(new_urban.And(mining_ref),     f"mining_to_urban_{ref_year}_{TARGET_YEAR}_ha"),
    ]

conversion_stack = conversion_bands[0]
for band in conversion_bands[1:]:
    conversion_stack = conversion_stack.addBands(band)

print("Conversion indicator stack assembled.")

# ------------------------------------------------------------
# 9. Extract conversion indicators per 1-km grid cell
# ------------------------------------------------------------

print("\nExtracting observed conversion indicators per 1-km grid cell...")

# [FIX-9] tileScale=4
conversion_ee = conversion_stack.reduceRegions(
    collection=grid_ee,
    reducer=ee.Reducer.sum(),
    scale=30,
    tileScale=4
)

# Note: if geemap.ee_to_gdf times out use Export:
#   task = ee.batch.Export.table.toDrive(
#       collection  = conversion_ee,
#       description = "nci_br_sjc_observed_conversion",
#       folder      = "NCI_BR_Exports", fileFormat = "CSV"
#   )
#   task.start(); print(f"Export task: {task.id}")

conversion_gdf = geemap.ee_to_gdf(conversion_ee)
if conversion_gdf.crs is None:
    conversion_gdf = conversion_gdf.set_crs("EPSG:4326")
conversion_gdf = conversion_gdf.to_crs(plot_crs)

conversion_gdf = ensure_grid_id(conversion_gdf, "conversion")

conversion_cols = [c for c in conversion_gdf.columns if c.endswith("_ha")]
conversion_gdf  = safe_numeric(conversion_gdf, conversion_cols)

print(f"Conversion grid: {len(conversion_gdf)} cells | {len(conversion_cols)} area bands")

# ------------------------------------------------------------
# 10. Merge with NCI-BR
# ------------------------------------------------------------

nci_cols = [c for c in [
    "grid_id", "NCI_BR", "NCI_BR_class", "NCI_BR_typology",
    "score_native_vegetation", "score_hydrological_regulation",
    "score_low_anthropic_pressure", "score_vegetation_condition",
    "LISA_cluster", "Gi_cluster",
] if c in nci_gdf.columns]

nci_table = pd.DataFrame(nci_gdf[nci_cols])

observed_gdf = conversion_gdf.merge(nci_table, on="grid_id", how="left")

for col in ["NCI_BR", "score_native_vegetation",
            "score_hydrological_regulation",
            "score_low_anthropic_pressure",
            "score_vegetation_condition"]:
    if col in observed_gdf.columns:
        observed_gdf[col] = pd.to_numeric(observed_gdf[col], errors="coerce")

print(f"Merged observed grid: {len(observed_gdf)} cells")

# ------------------------------------------------------------
# 11. [FIX-10] Annual urban trajectory — 1 GEE call (multiband)
# ------------------------------------------------------------
# Build a multiband image (one band per year) then reduce once.

print(f"\nBuilding annual urban trajectory {START_YEAR}–{TARGET_YEAR} (single GEE call)...")

year_bands = []
years_list = list(range(START_YEAR, TARGET_YEAR + 1))

for year in years_list:
    lulc  = clip_image_to_aoi(mapbiomas.select(f"classification_{year}"), aoi_geom)
    band  = (
        ee.Image.pixelArea().divide(1e4)
        .updateMask(lulc.eq(URBAN_CLASS))
        .rename(f"urban_{year}")
    )
    year_bands.append(band)

annual_stack = year_bands[0]
for b in year_bands[1:]:
    annual_stack = annual_stack.addBands(b)

annual_result = annual_stack.reduceRegion(
    reducer=ee.Reducer.sum(),
    geometry=aoi_geom,
    scale=30, maxPixels=1e13, bestEffort=True
).getInfo()

annual_urban_df = pd.DataFrame([
    {"year": yr, "urban_ha": float(annual_result.get(f"urban_{yr}", 0) or 0)}
    for yr in years_list
])

base_ha = float(annual_urban_df.loc[annual_urban_df["year"] == START_YEAR, "urban_ha"].iloc[0])
annual_urban_df["urban_change_since_1985_ha"] = annual_urban_df["urban_ha"] - base_ha

# [IMP-2] Per-decade expansion rates (ha/decade)
decades = [(1985, 1995), (1995, 2005), (2005, 2015), (2015, TARGET_YEAR)]
decade_records = []
for y0, y1 in decades:
    if y1 > TARGET_YEAR:
        y1 = TARGET_YEAR
    ha0 = float(annual_urban_df.loc[annual_urban_df["year"] == y0, "urban_ha"].iloc[0])
    ha1 = float(annual_urban_df.loc[annual_urban_df["year"] == y1, "urban_ha"].iloc[0])
    decade_records.append({
        "period": f"{y0}–{y1}",
        "urban_ha_start": round(ha0, 1),
        "urban_ha_end":   round(ha1, 1),
        "delta_ha":       round(ha1 - ha0, 1),
        "rate_ha_per_yr": round((ha1 - ha0) / max(y1 - y0, 1), 1),
    })
decade_df = pd.DataFrame(decade_records)

print(f"Annual urban trajectory computed: {len(annual_urban_df)} years")
print(f"\nDecadal expansion rates:")
print(decade_df.to_string(index=False))

# ------------------------------------------------------------
# 12. Observed impact accounting per reference year
# ------------------------------------------------------------

for ref_year in REFERENCE_YEARS:
    new_col    = f"new_urban_{ref_year}_{TARGET_YEAR}_ha"
    native_col = f"native_to_urban_{ref_year}_{TARGET_YEAR}_ha"

    observed_gdf[f"NCI_exposure_{ref_year}_{TARGET_YEAR}"] = (
        observed_gdf.get(new_col, 0) * observed_gdf["NCI_BR"]
    )
    observed_gdf[f"native_cap_exposure_{ref_year}_{TARGET_YEAR}"] = (
        observed_gdf.get(native_col, 0) * observed_gdf["score_native_vegetation"]
    )
    observed_gdf[f"hydro_cap_exposure_{ref_year}_{TARGET_YEAR}"] = (
        observed_gdf.get(new_col, 0) * observed_gdf["score_hydrological_regulation"]
    )

# ------------------------------------------------------------
# 13. [IMP-1] Conversion by NCI-BR class
# ------------------------------------------------------------
# What fraction of each NCI quintile class was converted to urban?

main_ref     = 1985
main_new_col = f"new_urban_{main_ref}_{TARGET_YEAR}_ha"

if "NCI_BR_class" in observed_gdf.columns and main_new_col in observed_gdf.columns:
    class_conversion = (
        observed_gdf.groupby("NCI_BR_class", observed=False)
        .agg(
            n_cells=("grid_id", "count"),
            total_new_urban_ha=(main_new_col, "sum"),
            mean_NCI_BR=("NCI_BR", "mean"),
        )
        .reset_index()
    )
    if "grid_area_ha" in observed_gdf.columns:
        class_area = observed_gdf.groupby("NCI_BR_class", observed=False)["grid_area_ha"].sum()
        class_conversion = class_conversion.merge(
            class_area.rename("total_cell_area_ha"), on="NCI_BR_class", how="left"
        )
        class_conversion["pct_class_converted"] = (
            class_conversion["total_new_urban_ha"] /
            class_conversion["total_cell_area_ha"].replace(0, np.nan) * 100
        ).round(2)
else:
    class_conversion = pd.DataFrame()

# ------------------------------------------------------------
# 14. AOI-level summary per reference year
# ------------------------------------------------------------

summary_records = []
for ref_year in REFERENCE_YEARS:
    new_col    = f"new_urban_{ref_year}_{TARGET_YEAR}_ha"
    native_col = f"native_to_urban_{ref_year}_{TARGET_YEAR}_ha"
    agri_col   = f"agri_to_urban_{ref_year}_{TARGET_YEAR}_ha"
    water_col  = f"water_to_urban_{ref_year}_{TARGET_YEAR}_ha"
    mining_col = f"mining_to_urban_{ref_year}_{TARGET_YEAR}_ha"
    nci_exp_col = f"NCI_exposure_{ref_year}_{TARGET_YEAR}"

    affected = observed_gdf[observed_gdf.get(new_col, pd.Series(0, index=observed_gdf.index)) > 0]

    summary_records.append({
        "reference_year":              ref_year,
        "target_year":                 TARGET_YEAR,
        "new_urban_ha":                round(observed_gdf[new_col].sum(),    1) if new_col    in observed_gdf.columns else 0,
        "native_to_urban_ha":          round(observed_gdf[native_col].sum(), 1) if native_col in observed_gdf.columns else 0,
        "agri_to_urban_ha":            round(observed_gdf[agri_col].sum(),   1) if agri_col   in observed_gdf.columns else 0,
        "water_to_urban_ha":           round(observed_gdf[water_col].sum(),  1) if water_col  in observed_gdf.columns else 0,
        "mining_to_urban_ha":          round(observed_gdf[mining_col].sum(), 1) if mining_col in observed_gdf.columns else 0,
        "affected_cells":              len(affected),
        "mean_NCI_converted_cells":    round(float(affected["NCI_BR"].mean()),   2) if len(affected) else np.nan,
        "median_NCI_converted_cells":  round(float(affected["NCI_BR"].median()), 2) if len(affected) else np.nan,
        "NCI_exposure_area_weighted":  round(observed_gdf[nci_exp_col].sum(),    2) if nci_exp_col in observed_gdf.columns else 0,
    })

summary_df = pd.DataFrame(summary_records)

# Top impacted cells 1985→TARGET_YEAR  [IMP-4]
main_nci_exp_col = f"NCI_exposure_{main_ref}_{TARGET_YEAR}"
if main_nci_exp_col in observed_gdf.columns:
    top_cells = (
        observed_gdf[observed_gdf[main_new_col] > 0]
        .sort_values(main_nci_exp_col, ascending=False)
        .head(30)
    )
else:
    top_cells = observed_gdf.head(0)

