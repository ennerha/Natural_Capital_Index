if main_new_col in plot_gdf.columns:
    plot_gdf.plot(
        column=main_new_col, ax=ax_b,
        cmap="Reds", linewidth=0.0, legend=True,
        legend_kwds={"label": "New urban area (ha)", "shrink": 0.7},
        missing_kwds={"color": "lightgrey"}
