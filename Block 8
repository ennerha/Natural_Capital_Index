# 15. Export products
# ------------------------------------------------------------

observed_path    = DIRS["processed"] / "nci_br_sjc_observed_conversion.gpkg"
observed_csv     = DIRS["tables"]    / "nci_br_sjc_observed_conversion.csv"
summary_path     = DIRS["tables"]    / "nci_br_sjc_observed_conversion_summary.csv"
annual_path      = DIRS["tables"]    / "nci_br_sjc_urban_trajectory_annual.csv"
decade_path      = DIRS["tables"]    / "nci_br_sjc_urban_expansion_rates.csv"
class_conv_path  = DIRS["tables"]    / "nci_br_sjc_conversion_by_nci_class.csv"
top_cells_path   = DIRS["tables"]    / "nci_br_sjc_top_conversion_cells.csv"

observed_gdf.to_file(observed_path, layer="observed_conversion", driver="GPKG")

