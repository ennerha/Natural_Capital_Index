    observed_csv, index=False, encoding="utf-8-sig"
)
summary_df.to_csv(summary_path,  index=False, encoding="utf-8-sig")
annual_urban_df.to_csv(annual_path,  index=False, encoding="utf-8-sig")
decade_df.to_csv(decade_path,   index=False, encoding="utf-8-sig")

if len(class_conversion) > 0:
    class_conversion.to_csv(class_conv_path, index=False, encoding="utf-8-sig")

pd.DataFrame(top_cells.drop(columns="geometry", errors="ignore")).to_csv(
    top_cells_path, index=False, encoding="utf-8-sig"
)

print(f"\nObserved conversion products exported:")
for p in [observed_path, observed_csv, summary_path, annual_path,
          decade_path, class_conv_path, top_cells_path]:
    print(f"  {p}")
logger.info(f"Observed conversion: {len(observed_gdf)} cells | {len(summary_df)} ref years")

# ------------------------------------------------------------
# 16. Prepare plotting layers
# ------------------------------------------------------------

plot_gdf  = observed_gdf.copy()
muni_plot = muni_gdf.to_crs(plot_crs)

for col in conversion_cols + ["NCI_BR", "score_native_vegetation"]:
    if col in plot_gdf.columns:
        plot_gdf[col] = pd.to_numeric(plot_gdf[col], errors="coerce")

xmin, ymin, xmax, ymax = muni_plot.total_bounds
xbuf = (xmax - xmin) * 0.05
ybuf = (ymax - ymin) * 0.05
map_extent = [xmin - xbuf, xmax + xbuf, ymin - ybuf, ymax + ybuf]


def overlay_boundary(ax, gdf):
    gdf.boundary.plot(ax=ax, edgecolor="black", linewidth=1.2, zorder=5)


def set_map_extent(ax):
    ax.set_xlim(map_extent[0], map_extent[1])
    ax.set_ylim(map_extent[2], map_extent[3])
    ax.set_axis_off()


def add_panel_label(ax, label):
    ax.text(0.02, 0.97, label, transform=ax.transAxes,
            fontsize=12, fontweight="bold", va="top", ha="left",
            bbox=dict(facecolor="white", edgecolor="none",
                      alpha=0.88, boxstyle="round,pad=0.22"))

main_native_col = f"native_to_urban_{main_ref}_{TARGET_YEAR}_ha"

# ------------------------------------------------------------
# 17. High-quality composite figure — 9 panels
# ------------------------------------------------------------

plt.rcParams.update({
    "figure.dpi": 150, "savefig.dpi": CONFIG["figure_dpi"],
    "font.family": "DejaVu Sans", "font.size": 9.5,
    "axes.titlesize": 10, "axes.labelsize": 9,
    "legend.fontsize": 8.5, "axes.linewidth": 0.7,
    "pdf.fonttype": 42, "ps.fonttype": 42, "savefig.bbox": "tight",
})

