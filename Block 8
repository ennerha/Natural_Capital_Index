overlay_boundary(ax_b, muni_plot)
set_map_extent(ax_b)
ax_b.set_title(f"Observed new urban area {main_ref}–{TARGET_YEAR} (ha/cell)", loc="left")
add_panel_label(ax_b, "b")

# ── Panel c — Native vegetation → urban ──────────────────────
if main_native_col in plot_gdf.columns:
    plot_gdf.plot(
        column=main_native_col, ax=ax_c,
        cmap="OrRd", linewidth=0.0, legend=True,
        legend_kwds={"label": "Native veg. → urban (ha)", "shrink": 0.7},
