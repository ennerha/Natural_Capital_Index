def find_column(df: pd.DataFrame, candidates: list, required: bool = True):
    """Return the first candidate column that exists in df."""
    for col in candidates:
        if col in df.columns:
            return col
    if required:
        raise ValueError(f"None of the candidate columns found: {candidates}")
    return None


def to_numeric_clean(series: pd.Series) -> pd.Series:
    return pd.to_numeric(series, errors="coerce").replace([np.inf, -np.inf], np.nan)


def percentile_score(series: pd.Series, invert: bool = False) -> pd.Series:
    """
    Rank-based 0–100 score.
    Design choice: percentile scoring ensures the index is always
    uniformly distributed [0, 100], making it robust to outliers
    and non-normal distributions. It is a relative measure —
    cells are scored against each other within the study area.
    [IMP-4]
    """
    x = to_numeric_clean(series)
    score = x.rank(pct=True) * 100
    return 100 - score if invert else score


def minmax_score(series: pd.Series, invert: bool = False) -> pd.Series:
    """Linear min-max rescaling to [0, 100]."""
    x = to_numeric_clean(series)
    xmin, xmax = x.min(), x.max()
    if pd.isna(xmin) or pd.isna(xmax) or xmax == xmin:
        return pd.Series(np.nan, index=x.index)
    score = (x - xmin) / (xmax - xmin) * 100
    return 100 - score if invert else score

