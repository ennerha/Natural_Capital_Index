def classify_typology(row):
    if row["high_natural_capital"] and row["high_anthropic_pressure"]:
        return "High NCI under pressure"
    if row["high_natural_capital"] and row["high_hydro_regulation"]:
        return "High NCI – hydro priority"
    if row["high_natural_capital"]:
        return "High NCI – conservation priority"
    if row["high_anthropic_pressure"]:
        return "Low NCI / high pressure"
    return "Intermediate"


