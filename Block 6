# ------------------------------------------------------------
# 8. NCI-BR composite index — base formulation
# ------------------------------------------------------------
# Weights reflect the first-version formulation.
# Component rationale:
#   native_vegetation      (30 %) — primary biodiversity and
#                                   ecosystem structure signal
#   vegetation_condition   (20 %) — vegetation health and function
#   hydrological_regulation(20 %) — water regulation service
#   low_anthropic_pressure (15 %) — absence of degradation
#   floodplain_function    (10 %) — lowland/riparian function [IMP-5]
#   vegetation_trend       ( 5 %) — trajectory / resilience proxy
#
# Design: percentile scoring + weighted mean with missing-value
# adjustment ensures cells with fewer valid inputs are not unduly
# penalised — their weights are renormalised to 1.

WEIGHTS = {
    "score_native_vegetation":       0.30,
    "score_vegetation_condition":    0.20,
    "score_hydrological_regulation": 0.20,
    "score_low_anthropic_pressure":  0.15,
    "score_floodplain_function":     0.10,
    "score_vegetation_trend":        0.05,
}

weighted_sum  = pd.Series(0.0, index=merged.index)
weight_sum    = pd.Series(0.0, index=merged.index)

for col, w in WEIGHTS.items():
    valid = merged[col].notna()
    weighted_sum.loc[valid] += merged.loc[valid, col] * w
    weight_sum.loc[valid]   += w

merged["NCI_BR_raw"] = weighted_sum / weight_sum
merged["NCI_BR"]     = minmax_score(merged["NCI_BR_raw"])

