        "score_vegetation_condition":    0.10,
        "score_hydrological_regulation": 0.40,
        "score_low_anthropic_pressure":  0.15,
        "score_floodplain_function":     0.10,
        "score_vegetation_trend":        0.05,
    },
    "equal_weights": {
        "score_native_vegetation":       1/6,
        "score_vegetation_condition":    1/6,
        "score_hydrological_regulation": 1/6,
        "score_low_anthropic_pressure":  1/6,
        "score_floodplain_function":     1/6,
        "score_vegetation_trend":        1/6,
    },
}

sensitivity_records = []
for scenario_name, w_dict in SCENARIOS.items():
    ws, wt = pd.Series(0.0, index=merged.index), pd.Series(0.0, index=merged.index)
    for col, w in w_dict.items():
        valid = merged[col].notna()
        ws.loc[valid] += merged.loc[valid, col] * w
        wt.loc[valid] += w
    raw  = ws / wt
    norm = minmax_score(raw)
    sensitivity_records.append({
        "scenario": scenario_name,
        "mean_NCI":   round(float(norm.mean()),   2),
        "median_NCI": round(float(norm.median()), 2),
        "std_NCI":    round(float(norm.std()),    2),
        "corr_base":  round(float(norm.corr(merged["NCI_BR"])), 4),
    })
    merged[f"NCI_BR_{scenario_name}"] = norm

