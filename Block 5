# 11. [IMP-2] Flood-susceptibility class breakdown
# ------------------------------------------------------------
# Classes: Low (<33), Moderate (33–66), High (>66)

def classify_score(series, label):
    low  = (series < 33).sum()
    mid  = ((series >= 33) & (series <= 66)).sum()
    high = (series > 66).sum()
    total = series.notna().sum()
    return {
        "indicator": label,
        "low_pct":      round(low  / total * 100, 1),
        "moderate_pct": round(mid  / total * 100, 1),
        "high_pct":     round(high / total * 100, 1),
        "n_cells":      int(total),
    }

flood_col_raw  = next((c for c in grid_hydro_gdf.columns
                        if "flood_susceptibility_score" in c and c.endswith("_mean")), None)
hydro_col_raw  = next((c for c in grid_hydro_gdf.columns
                        if "hydrological_regulation_score" in c and c.endswith("_mean")), None)

class_records = []
for col, label in [(flood_col_raw, "flood_susceptibility"),
                   (hydro_col_raw,  "hydrological_regulation")]:
    if col:
        vals = pd.to_numeric(grid_hydro_gdf[col], errors="coerce").dropna()
        class_records.append(classify_score(vals, label))

class_df   = pd.DataFrame(class_records)
