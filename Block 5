# ------------------------------------------------------------
# 5. Helper: clip_image_to_aoi (redefined inline)
# ------------------------------------------------------------

def clip_image_to_aoi(image: ee.Image, aoi_geometry: ee.Geometry) -> ee.Image:
    """Clip and mask an ee.Image to the exact municipal boundary."""
    return (
        image
        .clip(aoi_geometry)
        .updateMask(ee.Image.constant(1).clip(aoi_geometry).unmask(0))
    )

# ------------------------------------------------------------
# 6. Terrain and drainage datasets
# ------------------------------------------------------------
# Primary  : MERIT Hydro v1.0.1 (elevation, HAND, upstream area)
# Fallback : SRTM elevation + approximate HAND derivation
#
# MERIT Hydro bands used:
#   elv  — elevation (m)
#   hnd  — Height Above Nearest Drainage (m)
#   upa  — upstream drainage area (km²) [IMP-1]

terrain_source = None

try:
    merit_raw = ee.Image("MERIT/Hydro/v1_0_1")

    # [FIX-4] Apply clip_image_to_aoi to all rasters
    merit      = clip_image_to_aoi(merit_raw, aoi_geom)
    elevation  = merit.select("elv").rename("elevation_m")
    hand       = merit.select("hnd").rename("HAND_m")
    upstr_area = merit.select("upa").rename("upstream_area_km2")  # [IMP-1]

    terrain_source = "MERIT Hydro v1.0.1"
    print(f"Terrain source: {terrain_source}")

except Exception as e_merit:
    print(f"MERIT Hydro failed ({e_merit}). Falling back to SRTM.")

    srtm_raw  = ee.Image("USGS/SRTMGL1_003")
    elevation = clip_image_to_aoi(srtm_raw.select("elevation"), aoi_geom).rename("elevation_m")

    # [FIX-11] HAND proxy: elev minus local minimum, clamped >= 0
    # (approximation only — use MERIT when available)
    hand = (
        elevation
        .subtract(elevation.focal_min(radius=1500, units="meters"))
        .max(0)                    # HAND cannot be negative
        .rename("HAND_m")
    )
    upstr_area = None              # Not available from SRTM
    terrain_source = "SRTM (HAND approximated)"
    print(f"Terrain source: {terrain_source}")

# Slope from elevation (degrees)
slope = ee.Terrain.slope(elevation).rename("slope_deg")

print(f"Elevation, HAND, and slope layers ready.")

# ------------------------------------------------------------
# 7. JRC Global Surface Water — occurrence and water distance
# ------------------------------------------------------------
# occurrence: percentage of time a pixel was water (0–100 %)
# Threshold >= 25 % identifies permanent and recurrent water.
# [IMP-4] Threshold documented: 25 % ≈ water present ≥ 3 months/yr.

jrc_raw    = ee.Image("JRC/GSW1_4/GlobalSurfaceWater")
jrc        = clip_image_to_aoi(jrc_raw, aoi_geom)
occurrence = jrc.select("occurrence").rename("water_occurrence_pct")
seasonality = jrc.select("seasonality").rename("water_seasonality_months")

# Recurrent water mask (occurrence >= 25 %)
water_mask = occurrence.gte(25).selfMask().rename("water_mask")

# Distance to nearest recurrent water body (metres)
# fastDistanceTransform returns pixel-unit distances; multiply by pixel size.
# Note: output is an approximation at 30-m Landsat scale.
distance_to_water = (
    water_mask.unmask(0)
    .fastDistanceTransform(1024)
    .sqrt()
    .multiply(30)
    .rename("distance_to_water_m")
)

# Water proximity score: 100 = on water, 0 = ≥ 5 km away
water_proximity_score = (
    ee.Image(1)
    .subtract(distance_to_water.divide(5000).min(1))
    .multiply(100)
    .rename("water_proximity_score")
)

print("JRC Surface Water layers ready.")

# ------------------------------------------------------------
# 8. Flood-susceptibility and hydrological regulation scores
# ------------------------------------------------------------
# Scores range 0–100 (higher = more susceptible / higher regulation potential).
#
# Flood susceptibility weights [IMP-3]:
#   HAND        0.55  — primary lowland indicator
#   Slope       0.25  — secondary mobility indicator
#   Water prox. 0.20  — proximity to recurrent water bodies
#
# Hydrological regulation weights [IMP-3]:
#   Water prox. 0.40  — proximity to water bodies key for retention
#   HAND        0.35  — lowland areas retain water naturally
#   Slope       0.25  — low slope slows runoff

# Low-HAND binary flags (useful as area-fraction indicators)
hand_lte_2m  = hand.lte(2).rename("HAND_lte_2m")
hand_lte_5m  = hand.lte(5).rename("HAND_lte_5m")
hand_lte_10m = hand.lte(10).rename("HAND_lte_10m")
slope_lte_3  = slope.lte(3).rename("slope_lte_3deg")

# Component scores
hand_score = (
    ee.Image(1).subtract(hand.divide(20).min(1))
    .multiply(100).rename("hand_lowland_score")
)
slope_score = (
    ee.Image(1).subtract(slope.divide(15).min(1))
    .multiply(100).rename("low_slope_score")
)

flood_susceptibility_score = (
    hand_score.multiply(0.55)
    .add(slope_score.multiply(0.25))
    .add(water_proximity_score.multiply(0.20))
    .rename("flood_susceptibility_score")
)

hydrological_regulation_score = (
    water_proximity_score.multiply(0.40)
    .add(hand_score.multiply(0.35))
    .add(slope_score.multiply(0.25))
    .rename("hydrological_regulation_score")
)

