ybuf = (bounds[3] - bounds[1]) * 0.05

MAP_XLIM = (bounds[0] - xbuf, bounds[2] + xbuf)
MAP_YLIM = (bounds[1] - ybuf, bounds[3] + ybuf)

print(f"Municipality : {MUNICIPALITY}")
