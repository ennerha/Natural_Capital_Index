driver_lines = []

if not regression_coef.empty:
    coef_sub = regression_coef.copy()

    if "model" in coef_sub.columns:
        coef_sub = coef_sub[
            coef_sub["model"].astype(str).str.contains("OLS_HC3", na=False)
        ].copy()

    if "variable" in coef_sub.columns and "coef" in coef_sub.columns:
        coef_sub = coef_sub[
            coef_sub["variable"].astype(str).str.startswith("z_")
        ].copy()

        coef_sub["abs_coef"] = coef_sub["coef"].abs()
        coef_sub = coef_sub.sort_values("abs_coef", ascending=False).head(5)

        for _, row in coef_sub.iterrows():
            var = str(row["variable"]).replace("z_", "")
            p_value = row["p_value"] if "p_value" in row.index else np.nan

            if pd.notna(p_value):
                sig = "p ≤ 0.05" if p_value <= 0.05 else ("p ≤ 0.10" if p_value <= 0.10 else "n.s.")
            else:
                sig = "p unavailable"

            direction = "▲" if row["coef"] > 0 else "▼"
            driver_lines.append(f"  {direction} {var}   β = {row['coef']:.3f}   {sig}")

