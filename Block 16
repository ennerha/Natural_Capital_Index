# ------------------------------------------------------------
# 5. Synthesis classes
# ------------------------------------------------------------

nci_q75 = analysis["NCI_BR"].quantile(0.75)

analysis["converted_high_nci"] = (
    analysis[new_urban_col] > 0
) & (
    analysis["NCI_BR"] >= nci_q75
)

analysis["native_converted_high_nci"] = (
    analysis[native_to_urban_col] > 0
) & (
    analysis["NCI_BR"] >= nci_q75
)

analysis["robust_high_nci"] = (
    analysis["prob_high_nci_q75"].ge(0.75)
    if "prob_high_nci_q75" in analysis.columns
    else pd.Series(False, index=analysis.index)
)

analysis["floodplain_priority"] = (
    analysis["floodplain_fraction"].ge(0.50)
    if "floodplain_fraction" in analysis.columns
    else pd.Series(False, index=analysis.index)
)


def classify_final_evidence(row):
    if row["native_converted_high_nci"]:
        return "Observed native conversion in high-NCI cell"
    if row["converted_high_nci"]:
        return "Observed urban expansion in high-NCI cell"
    if row["robust_high_nci"] and row["floodplain_priority"]:
        return "Robust high-NCI floodplain priority"
    if row["robust_high_nci"]:
        return "Robust high-NCI conservation priority"
    if row[new_urban_col] > 0:
        return "Observed urban expansion"
    return "Other / lower priority"


analysis["final_evidence_class"] = analysis.apply(classify_final_evidence, axis=1)

