            ha="center",
            va="center",
            zorder=8,
            bbox=dict(
                facecolor="white",
                edgecolor="none",
                alpha=0.62,
                boxstyle="round,pad=0.18",
            ),
        )


def safe_choropleth(gdf, column, ax, cmap, title, unit_label=""):
    ax.set_facecolor(PALETTE["na_color"])

    if column not in gdf.columns:
        valid = pd.Series(dtype=float)
    else:
        valid = pd.to_numeric(gdf[column], errors="coerce").dropna()

    if valid.empty:
        gdf.plot(
            ax=ax,
            color=PALETTE["na_color"],
            linewidth=0,
        )

        ax.text(
            0.5,
            0.5,
            f"No data\n({column})",
            transform=ax.transAxes,
            ha="center",
            va="center",
            fontsize=8,
            color="#888888",
            bbox=dict(
                facecolor="white",
                edgecolor="none",
                alpha=0.75,
                boxstyle="round,pad=0.4",
            ),
        )

    else:
        vmin = float(valid.min())
        vmax = float(valid.max())

        if vmin == vmax:
            vmax = vmin + 1e-9

        plot_gdf = gdf.copy()
        plot_gdf["_v"] = pd.to_numeric(plot_gdf[column], errors="coerce")

        divider = make_axes_locatable(ax)
        cax = divider.append_axes("right", size="4%", pad=0.06)

        plot_gdf.plot(
            column="_v",
            ax=ax,
            cmap=cmap,
            linewidth=0,
            vmin=vmin,
            vmax=vmax,
            legend=True,
            legend_kwds={
                "cax": cax,
                "orientation": "vertical",
            },
            missing_kwds={
                "color": PALETTE["na_color"],
                "label": "No data",
            },
        )

        cax.tick_params(labelsize=6.5)

        if unit_label:
            cax.set_ylabel(
                unit_label,
                fontsize=6.2,
                labelpad=3,
            )

    _apply_mask(ax)
    _draw_boundary(ax)
    _apply_map_extent(ax)

    ax.set_title(
        title,
        fontsize=9,
        fontweight="bold",
        color=PALETTE["title_text"],
        pad=4,
        loc="center",
    )

    ax.set_axis_off()


def add_panel_label(ax, label):
