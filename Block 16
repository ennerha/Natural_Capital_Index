_bbox = shapely_box(MAP_XLIM[0], MAP_YLIM[0], MAP_XLIM[1], MAP_YLIM[1])
_muni_union = unary_union(muni_boundary.geometry.values)
_mask_geom = _bbox.difference(_muni_union)

mask_gdf = gpd.GeoDataFrame(
