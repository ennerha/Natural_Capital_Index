# ============================================================
# 9. BUILD TEMPORAL CARBON IMAGE STACK
# ============================================================

carbon_bands = []

print("\nBuilding ESA CCI temporal carbon stack...")

for year in BIOMASS_YEARS:
    print(f"  Processing ESA CCI biomass year: {year}")

    img = clip_image_to_aoi(
        ee.Image(f"{ESA_CCI_ASSET_PREFIX}/{year}"),
        aoi_geom,
    )

    agb = img.select("agb").rename(f"AGB_Mg_ha_{year}")
    agb_sd = img.select("agb_sd").rename(f"AGB_SD_Mg_ha_{year}")

    agc_density = agb.multiply(CARBON_FRACTION).rename(f"AGC_MgC_ha_{year}")
    agc_sd_density = agb_sd.multiply(CARBON_FRACTION).rename(f"AGC_SD_MgC_ha_{year}")

    agc_stock = (
        agc_density
        .multiply(ee.Image.pixelArea().divide(10000))
        .rename(f"AGC_stock_MgC_{year}")
    )

    agc_stock_sd = (
        agc_sd_density
        .multiply(ee.Image.pixelArea().divide(10000))
        .rename(f"AGC_stock_SD_MgC_{year}")
    )

    carbon_bands.extend([
        agc_density,
        agc_sd_density,
        agc_stock,
        agc_stock_sd,
    ])

carbon_stack = ee.Image.cat(carbon_bands).clip(aoi_geom)

agc_density_change = (
    carbon_stack.select(f"AGC_MgC_ha_{TARGET_CARBON_YEAR}")
    .subtract(carbon_stack.select(f"AGC_MgC_ha_{REFERENCE_CARBON_YEAR}"))
    .rename(f"AGC_density_change_MgC_ha_{REFERENCE_CARBON_YEAR}_{TARGET_CARBON_YEAR}")
)

agc_stock_change = (
    carbon_stack.select(f"AGC_stock_MgC_{TARGET_CARBON_YEAR}")
    .subtract(carbon_stack.select(f"AGC_stock_MgC_{REFERENCE_CARBON_YEAR}"))
    .rename(f"AGC_stock_change_MgC_{REFERENCE_CARBON_YEAR}_{TARGET_CARBON_YEAR}")
)

carbon_stack = carbon_stack.addBands([
    agc_density_change,
    agc_stock_change,
])

# ============================================================
# 10. MAPBIOMAS OBSERVED URBAN CONVERSION MASKS
# ============================================================

mapbiomas = ee.Image(CONFIG["mapbiomas_asset"])

lulc_ref = clip_image_to_aoi(
    mapbiomas.select(f"classification_{REF_LULC_YEAR}"),
    aoi_geom,
)

lulc_target = clip_image_to_aoi(
    mapbiomas.select(f"classification_{TARGET_LULC_YEAR}"),
    aoi_geom,
)

urban_ref = lulc_ref.eq(URBAN_CLASS)
urban_target = lulc_target.eq(URBAN_CLASS)

observed_new_urban = urban_target.And(urban_ref.Not())

native_ref = lulc_ref.remap(
    NATIVE_CLASSES,
    [1] * len(NATIVE_CLASSES),
    0,
).eq(1)

native_to_urban = observed_new_urban.And(native_ref)

carbon_exposed_new_urban = (
    carbon_stack.select(f"AGC_stock_MgC_{REFERENCE_CARBON_YEAR}")
    .updateMask(observed_new_urban)
    .rename(f"AGC_exposed_new_urban_MgC_{REFERENCE_CARBON_YEAR}_to_{TARGET_LULC_YEAR}")
)

carbon_exposed_native_to_urban = (
    carbon_stack.select(f"AGC_stock_MgC_{REFERENCE_CARBON_YEAR}")
    .updateMask(native_to_urban)
    .rename(f"AGC_exposed_native_to_urban_MgC_{REFERENCE_CARBON_YEAR}_to_{TARGET_LULC_YEAR}")
)

carbon_stack = carbon_stack.addBands([
    carbon_exposed_new_urban,
    carbon_exposed_native_to_urban,
])

# ============================================================
# 11. EXTRACT CARBON METRICS PER GRID CELL
# ============================================================

print("\nExtracting temporal carbon metrics per SJC 1-km cell...")

carbon_fc = carbon_stack.reduceRegions(
    collection=grid_ee,
    reducer=ee.Reducer.sum().combine(
        reducer2=ee.Reducer.mean(),
        sharedInputs=True,
    ),
    scale=100,
    tileScale=4,
)

carbon_gdf = geemap.ee_to_gdf(carbon_fc)

if carbon_gdf.crs is None:
    carbon_gdf = carbon_gdf.set_crs("EPSG:4326")

carbon_gdf = carbon_gdf.to_crs(OUTPUT_CRS)

print(f"Carbon grid extracted: {len(carbon_gdf)} cells")

# ============================================================
# 12. CLEAN COLUMNS AND DERIVE INDICATORS
# ============================================================

analysis_gdf = carbon_gdf.copy()

if "grid_id" in analysis_gdf.columns and "grid_id" in grid_gdf.columns:
    area_df = grid_gdf[["grid_id", "grid_area_ha"]].copy()

    if "grid_area_ha" in analysis_gdf.columns:
        analysis_gdf = analysis_gdf.drop(columns=["grid_area_ha"])

    analysis_gdf = analysis_gdf.merge(
        area_df,
        on="grid_id",
        how="left",
    )

if "grid_area_ha" not in analysis_gdf.columns:
    analysis_gdf["grid_area_ha"] = analysis_gdf.geometry.area / 10000

analysis_gdf["grid_area_ha"] = pd.to_numeric(
    analysis_gdf["grid_area_ha"],
    errors="coerce",
).fillna(analysis_gdf.geometry.area / 10000)

for year in BIOMASS_YEARS:
    density_col = find_col(
        analysis_gdf,
        f"AGC_MgC_ha_{year}",
        suffix="_mean",
    )

    density_sd_col = find_col(
        analysis_gdf,
        f"AGC_SD_MgC_ha_{year}",
        suffix="_mean",
    )

    stock_col = find_col(
        analysis_gdf,
        f"AGC_stock_MgC_{year}",
        suffix="_sum",
    )

    stock_sd_col = find_col(
        analysis_gdf,
        f"AGC_stock_SD_MgC_{year}",
        suffix="_sum",
    )

    for col in [density_col, density_sd_col, stock_col, stock_sd_col]:
        analysis_gdf[col] = pd.to_numeric(
            analysis_gdf[col],
            errors="coerce",
        ).fillna(0)

    analysis_gdf[f"carbon_density_MgC_ha_{year}"] = analysis_gdf[density_col]
    analysis_gdf[f"carbon_density_sd_MgC_ha_{year}"] = analysis_gdf[density_sd_col]
    analysis_gdf[f"carbon_stock_MgC_{year}"] = analysis_gdf[stock_col]
    analysis_gdf[f"carbon_stock_sd_MgC_{year}"] = analysis_gdf[stock_sd_col]

density_change_col = find_col(
    analysis_gdf,
    f"AGC_density_change_MgC_ha_{REFERENCE_CARBON_YEAR}_{TARGET_CARBON_YEAR}",
    suffix="_mean",
)

stock_change_col = find_col(
    analysis_gdf,
    f"AGC_stock_change_MgC_{REFERENCE_CARBON_YEAR}_{TARGET_CARBON_YEAR}",
    suffix="_sum",
)

exposed_new_col = find_col(
    analysis_gdf,
    f"AGC_exposed_new_urban_MgC_{REFERENCE_CARBON_YEAR}_to_{TARGET_LULC_YEAR}",
    suffix="_sum",
)

exposed_native_col = find_col(
    analysis_gdf,
    f"AGC_exposed_native_to_urban_MgC_{REFERENCE_CARBON_YEAR}_to_{TARGET_LULC_YEAR}",
    suffix="_sum",
)

for col in [density_change_col, stock_change_col, exposed_new_col, exposed_native_col]:
    analysis_gdf[col] = pd.to_numeric(
        analysis_gdf[col],
        errors="coerce",
    ).fillna(0)

analysis_gdf[f"carbon_density_change_MgC_ha_{REFERENCE_CARBON_YEAR}_{TARGET_CARBON_YEAR}"] = analysis_gdf[density_change_col]
analysis_gdf[f"carbon_stock_change_MgC_{REFERENCE_CARBON_YEAR}_{TARGET_CARBON_YEAR}"] = analysis_gdf[stock_change_col]
analysis_gdf["carbon_exposed_new_urban_MgC"] = analysis_gdf[exposed_new_col]
analysis_gdf["carbon_exposed_native_to_urban_MgC"] = analysis_gdf[exposed_native_col]

analysis_gdf[f"carbon_stock_tCO2e_{TARGET_CARBON_YEAR}"] = (
    analysis_gdf[f"carbon_stock_MgC_{TARGET_CARBON_YEAR}"] * CO2E_FACTOR
)

analysis_gdf[f"carbon_stock_change_tCO2e_{REFERENCE_CARBON_YEAR}_{TARGET_CARBON_YEAR}"] = (
    analysis_gdf[f"carbon_stock_change_MgC_{REFERENCE_CARBON_YEAR}_{TARGET_CARBON_YEAR}"] * CO2E_FACTOR
)

analysis_gdf["carbon_exposed_new_urban_tCO2e"] = (
    analysis_gdf["carbon_exposed_new_urban_MgC"] * CO2E_FACTOR
)

analysis_gdf["carbon_exposed_native_to_urban_tCO2e"] = (
    analysis_gdf["carbon_exposed_native_to_urban_MgC"] * CO2E_FACTOR
)

analysis_gdf["carbon_conservation_priority"] = (
    analysis_gdf[f"carbon_density_MgC_ha_{TARGET_CARBON_YEAR}"].rank(pct=True) * 100
)

loss_component = -analysis_gdf[f"carbon_density_change_MgC_ha_{REFERENCE_CARBON_YEAR}_{TARGET_CARBON_YEAR}"]

analysis_gdf["carbon_loss_risk"] = (
    loss_component.rank(pct=True) * 100
)

# ============================================================
# 13. MERGE WITH NCI-BR AND OBSERVED CONVERSION
# ============================================================

SYNTHESIS_CANDIDATES = [
    DIRS["processed"] / "nci_br_sjc_final_scientific_synthesis_map.gpkg",
    DIRS["processed"] / "nci_br_sjc_evidence_synthesis.gpkg",
    DIRS["processed"] / "nci_br_real_data_evidence_synthesis_map.gpkg",
]

synthesis_path = next((p for p in SYNTHESIS_CANDIDATES if p.exists()), None)

if synthesis_path is not None:
    synthesis_gdf = gpd.read_file(synthesis_path)

    if synthesis_gdf.crs is None:
        synthesis_gdf = synthesis_gdf.set_crs(OUTPUT_CRS)

    synthesis_gdf = synthesis_gdf.to_crs(OUTPUT_CRS)
    synthesis_gdf = gpd.clip(synthesis_gdf, muni_plot).reset_index(drop=True)

    keep_cols = [
        "grid_id",
        "NCI_BR",
        f"observed_new_urban_{REF_LULC_YEAR}_{TARGET_LULC_YEAR}_ha",
        f"native_to_urban_{REF_LULC_YEAR}_{TARGET_LULC_YEAR}_ha",
        f"NCI_exposed_by_observed_conversion_{REF_LULC_YEAR}_{TARGET_LULC_YEAR}",
        "final_evidence_class",
    ]

    keep_cols = [c for c in keep_cols if c in synthesis_gdf.columns]

    if "grid_id" in keep_cols:
        analysis_gdf = analysis_gdf.merge(
            synthesis_gdf[keep_cols].drop(columns="geometry", errors="ignore"),
            on="grid_id",
            how="left",
        )

    print(f"NCI-BR merged from: {synthesis_path.name}")

UNCERTAINTY_CANDIDATES = [
    DIRS["processed"] / "nci_br_sjc_uncertainty_sensitivity_analysis.gpkg",
    DIRS["processed"] / "nci_br_uncertainty_sensitivity_analysis.gpkg",
]

uncertainty_path = next((p for p in UNCERTAINTY_CANDIDATES if p.exists()), None)

if uncertainty_path is not None:
    uncertainty_gdf = gpd.read_file(uncertainty_path)

    keep_unc = [
        "grid_id",
        "prob_high_nci_q75",
        "high_nci_robustness_class",
    ]

    keep_unc = [c for c in keep_unc if c in uncertainty_gdf.columns]

    if "grid_id" in keep_unc:
        analysis_gdf = analysis_gdf.merge(
            uncertainty_gdf[keep_unc].drop(columns="geometry", errors="ignore"),
            on="grid_id",
            how="left",
        )

    print(f"Uncertainty merged from: {uncertainty_path.name}")

numeric_merge_cols = [
    "NCI_BR",
    f"observed_new_urban_{REF_LULC_YEAR}_{TARGET_LULC_YEAR}_ha",
    f"native_to_urban_{REF_LULC_YEAR}_{TARGET_LULC_YEAR}_ha",
    f"NCI_exposed_by_observed_conversion_{REF_LULC_YEAR}_{TARGET_LULC_YEAR}",
    "prob_high_nci_q75",
]

for col in numeric_merge_cols:
    if col in analysis_gdf.columns:
        analysis_gdf[col] = pd.to_numeric(
            analysis_gdf[col],
            errors="coerce",
        )

# ============================================================
# 14. CARBON–NATURAL CAPITAL COUPLING
# ============================================================

if "NCI_BR" in analysis_gdf.columns:
    carbon_q75 = analysis_gdf[f"carbon_density_MgC_ha_{TARGET_CARBON_YEAR}"].quantile(0.75)
    nci_q75 = analysis_gdf["NCI_BR"].quantile(0.75)

    analysis_gdf["high_carbon_2022"] = (
        analysis_gdf[f"carbon_density_MgC_ha_{TARGET_CARBON_YEAR}"] >= carbon_q75
    )

    analysis_gdf["high_natural_capital"] = (
        analysis_gdf["NCI_BR"] >= nci_q75
    )

    analysis_gdf["high_carbon_high_natural_capital"] = (
        analysis_gdf["high_carbon_2022"]
        & analysis_gdf["high_natural_capital"]
    )

    if "prob_high_nci_q75" in analysis_gdf.columns:
        analysis_gdf["robust_high_natural_capital"] = (
            pd.to_numeric(analysis_gdf["prob_high_nci_q75"], errors="coerce") >= 0.75
        )
    else:
        analysis_gdf["robust_high_natural_capital"] = False

    analysis_gdf["high_carbon_robust_high_natural_capital"] = (
        analysis_gdf["high_carbon_2022"]
        & analysis_gdf["robust_high_natural_capital"]
    )

urban_area_col = f"observed_new_urban_{REF_LULC_YEAR}_{TARGET_LULC_YEAR}_ha"

if urban_area_col in analysis_gdf.columns:
