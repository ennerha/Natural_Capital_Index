URBAN_CLASS = 24
NATIVE_CLASSES = [3, 4, 5, 6, 11, 12, 32, 49, 50]

# ============================================================
# 7. HELPER FUNCTIONS
# ============================================================

def clip_image_to_aoi(image, geom):
    return (
        image.clip(geom)
        .updateMask(ee.Image.constant(1).clip(geom).unmask(0))
    )


def find_col(df, startswith_text, suffix=None, required=True):
    matches = [c for c in df.columns if c.startswith(startswith_text)]

    if suffix is not None:
        matches_suffix = [c for c in matches if c.endswith(suffix)]
        if len(matches_suffix) > 0:
            return matches_suffix[0]

    if len(matches) > 0:
        return matches[0]

    if required:
        raise ValueError(f"No column found starting with: {startswith_text}")

    return None


def md5_checksum(fp: Path) -> str:
    h = hashlib.md5()
    with open(fp, "rb") as f:
        for chunk in iter(lambda: f.read(8192), b""):
            h.update(chunk)
    return h.hexdigest()


