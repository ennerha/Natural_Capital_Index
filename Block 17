def apply_extent(ax):
    ax.set_xlim(MAP_EXTENT[0], MAP_EXTENT[1])
    ax.set_ylim(MAP_EXTENT[2], MAP_EXTENT[3])
    ax.set_aspect("equal")
    ax.set_axis_off()


def safe_map(gdf, column, ax, cmap, title, unit_label=None, vmin=None, vmax=None, norm=None):
    if column not in gdf.columns or gdf[column].dropna().empty:
        gdf.plot(ax=ax, color="#e6e6e6", linewidth=0)
        ax.text(
            0.5,
            0.5,
            f"No data\n{column}",
            transform=ax.transAxes,
            ha="center",
            va="center",
            fontsize=8,
            color="#666666",
            bbox=dict(facecolor="white", edgecolor="none", alpha=0.80),
        )
    else:
        divider = make_axes_locatable(ax)
        cax = divider.append_axes("right", size="4%", pad=0.06)

        kwargs = dict(
            column=column,
            ax=ax,
            cmap=cmap,
            linewidth=0,
            legend=True,
            missing_kwds={"color": "#e6e6e6"},
            legend_kwds={"cax": cax, "orientation": "vertical"},
        )

        if norm is not None:
            kwargs["norm"] = norm
        else:
            if vmin is not None:
                kwargs["vmin"] = vmin
            if vmax is not None:
                kwargs["vmax"] = vmax

        gdf.plot(**kwargs)

        cax.tick_params(labelsize=6.5)
        if unit_label:
            cax.set_ylabel(unit_label, fontsize=6.5, labelpad=3)

    overlay_boundary(ax)
    apply_extent(ax)
    ax.set_title(title, loc="left", fontsize=9.5, fontweight="bold")


