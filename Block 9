    "Converted high-NCI cell":             "#b2182b",
    "Native vegetation → urban":           "#ef8a62",
    "High-NCI conservation priority":      "#1b7837",
    "Low-NCI / degraded or transformed":   "#969696",
    "Intermediate":                        "#d9f0a3",
}

# [FIX-10] NaN-safe color mapping
