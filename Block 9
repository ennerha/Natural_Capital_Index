total_nat_to_urb  = float(observed_gdf[main_nat_col].sum())
total_agri_to_urb = float(observed_gdf[main_agri_col].sum())
total_nci_exp     = float(observed_gdf[main_nci_exp].sum())
total_hyd_exp     = float(observed_gdf[main_hyd_exp].sum()) if main_hyd_exp else np.nan

converted_cells       = observed_gdf[observed_gdf[main_new_col] > 0]
native_conv_cells     = observed_gdf[observed_gdf[main_nat_col] > 0]

synthesis_records = [
    ("Total grid cells in municipality",              total_cells,          "cells"),
    ("Total grid area",                               total_area,           "ha"),
    (f"New urban/infra {MAIN_REF_YEAR}–{TARGET_YEAR}", total_new_urban,    "ha"),
    (f"Native → urban {MAIN_REF_YEAR}–{TARGET_YEAR}", total_nat_to_urb,    "ha"),
    (f"Agri. → urban {MAIN_REF_YEAR}–{TARGET_YEAR}",  total_agri_to_urb,   "ha"),
    ("Cells with any observed conversion",            len(converted_cells), "cells"),
    ("Cells with native-to-urban conversion",         len(native_conv_cells),"cells"),
    ("Mean NCI-BR in converted cells",                converted_cells["NCI_BR"].mean(), "0–100"),
    ("Mean NCI-BR in native-to-urban cells",          native_conv_cells["NCI_BR"].mean(),"0–100"),
    ("Area-weighted NCI exposure (conversion)",       total_nci_exp,        "NCI × ha"),
    ("Area-weighted hydro. exposure (conversion)",    total_hyd_exp,        "score × ha"),
]

# [IMP-2] Append spatial autocorrelation summary if available
if len(moran_df) > 0 and "variable" in moran_df.columns:
    nci_row = moran_df[moran_df["variable"] == "NCI_BR"]
    if len(nci_row) > 0:
        r = nci_row.iloc[0]
        synthesis_records += [
            ("Global Moran's I (NCI-BR)",    float(r.get("moran_I", np.nan)),  "index"),
            ("Moran's I p-value (NCI-BR)",   float(r.get("p_value",  np.nan)), "p"),
        ]

if len(lisa_summary) > 0:
    hh = lisa_summary[lisa_summary.get("LISA_cluster", pd.Series(dtype=str)) == "High-High"]
    if len(hh) > 0:
        synthesis_records.append(
            ("High-High LISA cells (NCI-BR)", int(hh["n_cells"].iloc[0]), "cells")
        )

synthesis = pd.DataFrame(synthesis_records, columns=["metric", "value", "unit"])

# ------------------------------------------------------------
# 7. [FIX-8] Category summary — guarded grid_area_ha
# ------------------------------------------------------------

