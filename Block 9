    ax_g.text(v + max(cat_cnt["n_cells"]) * 0.01, i,
              str(v), va="center", fontsize=7.5)
ax_g.set_title("Cells per evidence class", loc="left")
ax_g.set_xlabel("Number of 1-km cells")
ax_g.tick_params(axis="y", labelsize=7.5)
