# ── Panel g — Conversion by evidence class (counts) ──────────
cat_cnt = cat_summary.sort_values("n_cells")
short_g = [
    l.replace("Native vegetation → urban", "Native → urban")
     .replace("High-NCI conservation priority", "High-NCI priority")
     .replace("Low-NCI / degraded or transformed", "Low-NCI / degraded")
     .replace("Converted high-NCI cell", "Converted high-NCI")
    for l in cat_cnt["evidence_class"]
]
colors_g = [CLASS_COLORS.get(l, "#d9d9d9") for l in cat_cnt["evidence_class"]]

ax_g.barh(short_g, cat_cnt["n_cells"],
          color=colors_g, edgecolor="white", linewidth=0.5)
