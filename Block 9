# ------------------------------------------------------------
# 4. [FIX-7 / FIX-9] Detect observed conversion columns
# ------------------------------------------------------------
# Block 08 corrected uses: new_urban_*, native_to_urban_*,
# agri_to_urban_*, NCI_exposure_*, hydro_cap_exposure_*

def find_column(df: pd.DataFrame, candidates: list, required: bool = True):
    for c in candidates:
        if c in df.columns:
            return c
    if required:
        raise ValueError(
            f"None of the candidate columns found: {candidates}\n"
            f"Available: {[c for c in df.columns if 'urban' in c.lower() or 'nci' in c.lower()]}"
        )
    return None


main_new_col  = find_column(observed_gdf, [
    f"new_urban_{MAIN_REF_YEAR}_{TARGET_YEAR}_ha",
    f"observed_new_urban_{MAIN_REF_YEAR}_{TARGET_YEAR}_ha",
])
main_nat_col  = find_column(observed_gdf, [
    f"native_to_urban_{MAIN_REF_YEAR}_{TARGET_YEAR}_ha",
])
main_agri_col = find_column(observed_gdf, [
    f"agri_to_urban_{MAIN_REF_YEAR}_{TARGET_YEAR}_ha",
    f"agriculture_to_urban_{MAIN_REF_YEAR}_{TARGET_YEAR}_ha",
])
main_nci_exp  = find_column(observed_gdf, [
    f"NCI_exposure_{MAIN_REF_YEAR}_{TARGET_YEAR}",
    f"NCI_exposed_by_observed_conversion_{MAIN_REF_YEAR}_{TARGET_YEAR}",
])
main_hyd_exp  = find_column(observed_gdf, [
    f"hydro_cap_exposure_{MAIN_REF_YEAR}_{TARGET_YEAR}",
    f"hydrological_capital_exposed_{MAIN_REF_YEAR}_{TARGET_YEAR}",
], required=False)

# [FIX-11] Detect annual urban area column (Block 08 exports "urban_ha")
