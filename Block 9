print(f"\nColumn mapping resolved:")
print(f"  New urban     : {main_new_col}")
print(f"  Native→urban  : {main_nat_col}")
print(f"  Agri→urban    : {main_agri_col}")
print(f"  NCI exposure  : {main_nci_exp}")
print(f"  Hydro exposure: {main_hyd_exp}")
print(f"  Annual urban  : {urban_ha_col}")

# ------------------------------------------------------------
# 5. Evidence-based priority classification
# ------------------------------------------------------------

nci_q75 = float(observed_gdf["NCI_BR"].quantile(0.75))
nci_q25 = float(observed_gdf["NCI_BR"].quantile(0.25))


def classify_evidence(row) -> str:
    has_new_urban  = row[main_new_col]  > 0
    has_native_urb = row[main_nat_col]  > 0
    nci            = row["NCI_BR"]

    if has_new_urban and nci >= nci_q75:
        return "Converted high-NCI cell"
    if has_native_urb:
        return "Native vegetation → urban"
    if nci >= nci_q75:
        return "High-NCI conservation priority"
    if nci <= nci_q25:
        return "Low-NCI / degraded or transformed"
    return "Intermediate"


observed_gdf["evidence_class"] = observed_gdf.apply(classify_evidence, axis=1)

# ------------------------------------------------------------
# 6. Synthesis statistics
# ------------------------------------------------------------

total_cells = len(observed_gdf)
total_area  = float(observed_gdf["grid_area_ha"].sum()) if "grid_area_ha" in observed_gdf.columns else np.nan

