# ── Source 1: IBGE Malhas API ────────────────────────────────

def load_from_ibge_api(code: int, name: str, raw_dir: Path,
                        timeout: int = 30) -> gpd.GeoDataFrame:
    """Download municipal polygon from the IBGE Malhas v3 API."""
    url = (
        f"https://servicodados.ibge.gov.br/api/v3/malhas/municipios"
        f"/{code}?formato=application/json&qualidade=maxima"
    )
    print(f"    Downloading {name} (code {code}) from IBGE API...")
    resp = requests.get(url, timeout=timeout)
    resp.raise_for_status()

    gdf = gpd.read_file(io.BytesIO(resp.content))
    gdf["NM_MUN"]   = name
    gdf["CD_MUN"]   = str(code)
    gdf["SIGLA_UF"] = STATE_CODE
    gdf["source"]   = "ibge_api_malhas_v3"

    out = raw_dir / f"ibge_muni_{code}.geojson"
    gdf.to_file(out, driver="GeoJSON")

    if gdf.crs is None or gdf.crs.to_epsg() != 4326:
        gdf = gdf.set_crs("EPSG:4326")
    return gdf.to_crs("EPSG:4674")


# ── Source 2: IBGE FTP — full São Paulo state shapefile ──────

def load_from_ibge_ftp(code: int, name: str, raw_dir: Path,
                        timeout: int = 120) -> gpd.GeoDataFrame:
    """Download the SP state shapefile and filter by IBGE code."""
    url = (
        "https://geoftp.ibge.gov.br/organizacao_do_territorio/"
        "malhas_territoriais/malhas_municipais/municipio_2022/"
        "UFs/SP/SP_Municipios_2022.zip"
    )
    print("    Downloading SP shapefile from IBGE FTP (~60 s)...")
    resp = requests.get(url, timeout=timeout)
    resp.raise_for_status()

    zip_path = raw_dir / "SP_Municipios_2022.zip"
    with open(zip_path, "wb") as f:
        f.write(resp.content)

    extract_dir = raw_dir / "SP_Municipios_2022"
    extract_dir.mkdir(exist_ok=True)
    with zipfile.ZipFile(zip_path, "r") as z:
        z.extractall(extract_dir)

    shp_files = list(extract_dir.glob("*.shp"))
    if not shp_files:
        raise FileNotFoundError("No .shp found in IBGE FTP ZIP.")

    sp_gdf = gpd.read_file(shp_files[0]).to_crs("EPSG:4674")

    code_col = next(
        (c for c in sp_gdf.columns if "CD_MUN" in c.upper() or "GEOCMU" in c.upper()),
        None
    )
    if code_col is None:
        raise KeyError(f"Code column not found. Available: {sp_gdf.columns.tolist()}")

    result = sp_gdf[sp_gdf[code_col].astype(str) == str(code)].copy()
    if len(result) == 0:
        raise ValueError(f"Municipality code {code} not found in SP shapefile.")

    result["NM_MUN"] = name
    result["source"] = "ibge_ftp_sp_municipios_2022"
    return result


# ── Source 3: GADM v4.1 public GEE asset ─────────────────────

def load_from_gadm_gee(name: str) -> tuple:
    """Load municipal polygon from the public GADM v4.1 GEE asset."""
    gadm = ee.FeatureCollection("projects/sat-io/open-geodata/GADM/gadm41_BRA_2")
    fc   = gadm.filter(ee.Filter.eq("NAME_2", name))

    gdf = geemap.ee_to_gdf(fc)
    if gdf.crs is None:
        gdf = gdf.set_crs("EPSG:4326")
    gdf = gdf.to_crs("EPSG:4674")
    gdf["NM_MUN"]   = name
    gdf["SIGLA_UF"] = STATE_CODE
    gdf["source"]   = "gadm_v41_gee_level2"
    return fc, gdf


