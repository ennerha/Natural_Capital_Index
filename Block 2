# 14. Helper — clip_raster_to_municipality (local GeoTIFFs)
# ------------------------------------------------------------

def clip_raster_to_municipality(
    raster_path: Path,
    muni_gdf: gpd.GeoDataFrame,
    output_path: Path,
    nodata: float = -9999
) -> Path:
    """
    Clip a GeoTIFF to the exact municipal polygon using rasterio.
    Apply to every GeoTIFF downloaded from GEE before local analysis.

    Usage:
        clip_raster_to_municipality(
            DIRS["raw"] / "mapbiomas_2024_raw.tif",
            muni_gdf,
            DIRS["processed"] / "mapbiomas_2024_sjc.tif"
        )
    """
    with rasterio.open(raster_path) as src:
        muni_reproj = muni_gdf.to_crs(src.crs)
        shapes      = [mapping(geom) for geom in muni_reproj.geometry]

        out_image, out_transform = rio_mask(
            src, shapes, crop=True, filled=True, nodata=nodata
        )
        out_meta = src.meta.copy()
        out_meta.update({
            "driver": "GTiff", "height": out_image.shape[1],
            "width":  out_image.shape[2], "transform": out_transform,
            "nodata": nodata, "compress": "lzw",
        })

    output_path.parent.mkdir(parents=True, exist_ok=True)
    with rasterio.open(output_path, "w", **out_meta) as dest:
        dest.write(out_image)

    size_mb = output_path.stat().st_size / 1e6
    print(f"Raster clipped: {output_path.name} ({size_mb:.2f} MB)")
    logger.info(f"Raster clipped: {output_path}")
    return output_path

