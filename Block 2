def add_location_inset(ax, muni_wgs84, bbox_axes=(0.62, 0.01, 0.37, 0.32)):
    """
    Add a Brazil-scale location inset to panel ax.
    Uses cartopy if available; falls back to a simple placeholder.
    """
    try:
        import cartopy.crs as ccrs
        import cartopy.feature as cfeature

        ax_in = ax.inset_axes(bbox_axes, projection=ccrs.PlateCarree())
        ax_in.set_extent([-74, -28, -34, 6], crs=ccrs.PlateCarree())
        ax_in.add_feature(cfeature.LAND,      facecolor="#efefef", zorder=1)
        ax_in.add_feature(cfeature.BORDERS,   linewidth=0.4,       zorder=2)
        ax_in.add_feature(cfeature.COASTLINE, linewidth=0.4,       zorder=3)
        centroid = muni_wgs84.geometry.centroid.iloc[0]
        ax_in.plot(centroid.x, centroid.y, "r^", markersize=6,
                   transform=ccrs.PlateCarree(), zorder=5)
        ax_in.set_axis_off()
        ax_in.set_title("Location", fontsize=7, pad=2)

    except Exception:
        ax_in = ax.inset_axes(bbox_axes)
        ax_in.set_xlim(-74, -28)
        ax_in.set_ylim(-34, 6)
        ax_in.set_facecolor("#d8eaf5")
        ax_in.axhline(0, color="gray", linewidth=0.3, linestyle="--")
        centroid = muni_wgs84.geometry.centroid.iloc[0]
        ax_in.plot(centroid.x, centroid.y, "r^", markersize=6)
        ax_in.set_xticks([])
        ax_in.set_yticks([])
        ax_in.set_title("Location", fontsize=7, pad=2)
        for spine in ["top", "right"]:
            ax_in.spines[spine].set_visible(False)

