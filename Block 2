# 13. Helper — clip_image_to_aoi (reuse in all subsequent blocks)
# ------------------------------------------------------------

def clip_image_to_aoi(image: ee.Image, aoi_geometry: ee.Geometry) -> ee.Image:
    """
    Clip and mask an ee.Image to the exact municipal boundary.
    REQUIRED for every raster in all subsequent blocks.

    Usage:
        img = clip_image_to_aoi(ee.Image("USGS/SRTMGL1_003"), aoi_geom)
    """
    return (
        image
        .clip(aoi_geometry)
        .updateMask(
            ee.Image.constant(1).clip(aoi_geometry).unmask(0)
        )
    )


