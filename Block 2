def add_north_arrow(ax, x=0.94, y=0.93, size=0.07):
    ax.annotate(
        "N", xy=(x, y), xytext=(x, y - size),
        xycoords="axes fraction",
        ha="center", va="center",
        fontsize=11, fontweight="bold",
        arrowprops=dict(facecolor="black", edgecolor="black",
                        width=2.5, headwidth=8, headlength=10)
    )


def add_scale_bar(ax, length_km=20, location=(0.07, 0.055), linewidth=3):
    xlim = ax.get_xlim()
    ylim = ax.get_ylim()
    x0   = xlim[0] + (xlim[1] - xlim[0]) * location[0]
    y0   = ylim[0] + (ylim[1] - ylim[0]) * location[1]
    lm   = length_km * 1000
    ax.plot([x0, x0 + lm], [y0, y0],
            color="black", linewidth=linewidth, solid_capstyle="butt")
    ax.text(x0 + lm / 2, y0 + (ylim[1] - ylim[0]) * 0.016,
            f"{length_km} km", ha="center", va="bottom", fontsize=8.5)


def add_panel_label(ax, label):
