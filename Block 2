def create_square_grid(
    gdf: gpd.GeoDataFrame,
    cell_size_m: int = 1000,
    crs_projected: str = "EPSG:5880"
) -> gpd.GeoDataFrame:
    """
    Create a regular square grid and clip it to the exact
    municipal polygon. Uses numpy for performance.
    """
    gdf_proj = gdf.to_crs(crs_projected)
    xmin, ymin, xmax, ymax = gdf_proj.total_bounds

    xs = np.arange(xmin, xmax, cell_size_m)
    ys = np.arange(ymin, ymax, cell_size_m)

    cells = [
        box(x, y, x + cell_size_m, y + cell_size_m)
        for x in xs for y in ys
    ]

    grid = gpd.GeoDataFrame(
        {"grid_id": range(len(cells)), "geometry": cells},
        crs=crs_projected
    )

    # Exact clip by municipal polygon (not by bounding box)
    grid_clipped = gpd.overlay(
        grid,
        gdf_proj[["geometry"]],
        how="intersection",
        keep_geom_type=True
    ).reset_index(drop=True)

    grid_clipped["grid_id"]       = grid_clipped.index
    grid_clipped["grid_area_ha"]  = grid_clipped.geometry.area / 1e4
    grid_clipped["grid_area_km2"] = grid_clipped.geometry.area / 1e6

    # Border cells: area < 95 % of a full cell
    full_cell_ha = (cell_size_m ** 2) / 1e4
    grid_clipped["is_border_cell"] = (
        grid_clipped["grid_area_ha"] < full_cell_ha * 0.95
    )

    return grid_clipped


