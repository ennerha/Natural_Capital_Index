def make_cluster_summary(gdf, group_col):
    agg = {"NCI_BR": ["count", "mean", "median"]}
    if "grid_area_ha" in gdf.columns:
        agg["grid_area_ha"] = "sum"
    df = (
        gdf.groupby(group_col)
        .agg(agg)
        .reset_index()
    )
    df.columns = [
        group_col, "n_cells", "mean_NCI_BR", "median_NCI_BR"
    ] + (["total_area_ha"] if "grid_area_ha" in gdf.columns else [])
    return df.sort_values("mean_NCI_BR", ascending=False)


