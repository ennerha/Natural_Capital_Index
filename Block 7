# ------------------------------------------------------------
# 6. Spatial weights
# ------------------------------------------------------------
# Row-standardised Queen contiguity for Moran's I and LISA.
# Separate untransformed (binary) Queen weights for G_Local
# to avoid double row-standardisation. [FIX-12]

def build_weights(gdf: gpd.GeoDataFrame) -> tuple:
    """
    Returns (w_row, w_bin, weights_type).
    w_row : row-standardised weights (Moran, LISA)
    w_bin : binary weights            (G_Local / Gi*)
    """
    try:
        # [FIX-9] No ids kwarg — let libpysal use the DataFrame index
        w = Queen.from_dataframe(gdf)

        if len(w.islands) > 0:
            print(f"  Queen: {len(w.islands)} islands found. Switching to KNN-8.")
            w = KNN.from_dataframe(gdf, k=8)
            wtype = "KNN-8"
        else:
            wtype = "Queen contiguity"

    except Exception as e:
        print(f"  Queen weights failed ({e}). Using KNN-8.")
        w = KNN.from_dataframe(gdf, k=8)
        wtype = "KNN-8"

    # Binary copy for G_Local
    w_bin = w
    w_bin.transform = "b"   # binary

    # Row-standardised copy for Moran / LISA
    w_row = w
    w_row.transform = "r"

    return w_row, w_bin, wtype


w_row, w_bin, weights_type = build_weights(gdf)
print(f"Spatial weights: {weights_type}")
logger.info(f"Weights: {weights_type}")

# ------------------------------------------------------------
# 7. Global Moran's I — two-tailed test
# ------------------------------------------------------------
# [FIX-13] two_tailed=True (default): the composite NCI-BR can
# exhibit either positive (clustering of high/low values) or
# negative (spatial dispersion) autocorrelation. A two-tailed
# test is appropriate here.

print(f"\nComputing Global Moran's I ({len(available_vars)} variables)...")

moran_records = []

for var in available_vars:
    y = gdf[var].values
    mi = Moran(y, w_row, permutations=999, two_tailed=True)
    moran_records.append({
        "variable":    var,
        "moran_I":     round(mi.I,     4),
        "expected_I":  round(mi.EI,    4),
        "z_score":     round(mi.z_sim, 3),
        "p_value":     round(mi.p_sim, 4),
        "significant": mi.p_sim <= SIG_LEVEL,
        "permutations": 999,
        "test":         "two-tailed",
        "weights":      weights_type,
    })

moran_df   = pd.DataFrame(moran_records)
moran_path = DIRS["tables"] / "nci_br_sjc_global_morans_i.csv"
moran_df.to_csv(moran_path, index=False, encoding="utf-8-sig")

print("\nGlobal Moran's I results:")
