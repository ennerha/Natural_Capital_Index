# ------------------------------------------------------------
# 8. Local Moran's I / LISA for NCI-BR
# ------------------------------------------------------------

print(f"\nComputing Local Moran's I (LISA) for NCI-BR...")

y_nci = gdf["NCI_BR"].values
lisa  = Moran_Local(y_nci, w_row, permutations=999, seed=42)

gdf["LISA_I"]           = lisa.Is
gdf["LISA_p"]           = lisa.p_sim
gdf["LISA_q"]           = lisa.q
gdf["LISA_significant"] = lisa.p_sim <= SIG_LEVEL


def classify_lisa(row) -> str:
    if not row["LISA_significant"]:
        return "Not significant"
    q_map = {1: "High-High", 2: "Low-High", 3: "Low-Low", 4: "High-Low"}
    return q_map.get(int(row["LISA_q"]), "Not significant")


gdf["LISA_cluster"] = gdf.apply(classify_lisa, axis=1)

# ------------------------------------------------------------
# 9. Getis-Ord Gi* hotspots for NCI-BR
# ------------------------------------------------------------
# [FIX-12] Use binary weights (w_bin) to avoid double-standardisation.
# star=True includes the focal cell (Gi* vs Gi).

print("Computing Getis-Ord Gi* hotspots...")

gi = G_Local(y_nci, w_bin, transform="B", permutations=999, star=True, seed=42)

gdf["GiZScore"] = gi.Zs
gdf["GiPValue"] = gi.p_sim


def classify_gi(row) -> str:
    z, p = row["GiZScore"], row["GiPValue"]
    if   p <= 0.01 and z > 0: return "Hotspot 99%"
    elif p <= 0.05 and z > 0: return "Hotspot 95%"
    elif p <= 0.10 and z > 0: return "Hotspot 90%"
    elif p <= 0.01 and z < 0: return "Coldspot 99%"
    elif p <= 0.05 and z < 0: return "Coldspot 95%"
    elif p <= 0.10 and z < 0: return "Coldspot 90%"
    else:                      return "Not significant"


gdf["Gi_cluster"] = gdf.apply(classify_gi, axis=1)

