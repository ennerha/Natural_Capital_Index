def add_time_band(image: ee.Image) -> ee.Image:
    """Add a float 'time' band equal to the 'year' property."""
    return image.addBands(
        ee.Image.constant(ee.Number(image.get("year"))).rename("time").float()
    )

annual_with_time = annual_ic.map(add_time_band)
dry_with_time    = dry_ic.map(add_time_band)

# linearFit: band order [independent=time, dependent=NDVI/EVI]
ndvi_trend = (
    annual_with_time.select(["time", "NDVI"])
    .reduce(ee.Reducer.linearFit())
    .select("scale")
    .rename("NDVI_slope_series")
)
evi_trend = (
    annual_with_time.select(["time", "EVI"])
    .reduce(ee.Reducer.linearFit())
    .select("scale")
    .rename("EVI_slope_series")
)
ndvi_dry_trend = (
    dry_with_time.select(["time", "NDVI"])
    .reduce(ee.Reducer.linearFit())
    .select("scale")
    .rename("NDVI_dry_slope_series")
)

# Stack all indicators into a single multi-band image
veg_stack = (
    ndvi_baseline
    .addBands(evi_baseline)
    .addBands(ndvi_dry_baseline)
    .addBands(mean_ndvi)
    .addBands(mean_evi)
    .addBands(ndvi_trend)
    .addBands(evi_trend)
    .addBands(ndvi_dry_trend)
    .addBands(cv_ndvi)
    .addBands(mean_n_obs)
)

