def clip_image_to_aoi(image: ee.Image, aoi_geometry: ee.Geometry) -> ee.Image:
    """Clip and mask an ee.Image to the exact municipal boundary."""
    return (
        image
        .clip(aoi_geometry)
        .updateMask(ee.Image.constant(1).clip(aoi_geometry).unmask(0))
    )

# ------------------------------------------------------------
# 7. Landsat Collection 2 Level 2 preprocessing functions
# ------------------------------------------------------------

def mask_landsat_c2_l2(image: ee.Image) -> ee.Image:
    """
    Apply QA_PIXEL cloud/shadow/snow mask and convert to
    surface reflectance (scale factor 0.0000275, offset -0.2).
    Bits masked: 1=dilated cloud, 2=cirrus, 3=cloud,
                 4=cloud shadow, 5=snow.
    """
    qa = image.select("QA_PIXEL")
    mask = (
        qa.bitwiseAnd(1 << 1).eq(0)
        .And(qa.bitwiseAnd(1 << 2).eq(0))
        .And(qa.bitwiseAnd(1 << 3).eq(0))
        .And(qa.bitwiseAnd(1 << 4).eq(0))
        .And(qa.bitwiseAnd(1 << 5).eq(0))
    )
    optical = image.select("SR_B.*").multiply(0.0000275).add(-0.2)
    return image.addBands(optical, None, True).updateMask(mask)


def rename_landsat_8_9(image: ee.Image) -> ee.Image:
    """Rename Landsat 8/9 bands to generic names."""
    return image.select(
        ["SR_B2", "SR_B3", "SR_B4", "SR_B5", "SR_B6", "SR_B7"],
        ["blue",  "green", "red",   "nir",   "swir1", "swir2"]
    ).copyProperties(image, image.propertyNames())


def add_indices(image: ee.Image) -> ee.Image:
    """
    Compute NDVI and EVI, clamped to [-1, 1].
    [IMP-1] Clamping removes extreme outliers over water/shadow.
    """
    ndvi = (
        image.normalizedDifference(["nir", "red"])
        .rename("NDVI")
        .clamp(-1, 1)
    )
    evi = (
        image.expression(
            "2.5 * ((NIR - RED) / (NIR + 6 * RED - 7.5 * BLUE + 1))",
            {"NIR": image.select("nir"),
             "RED": image.select("red"),
             "BLUE": image.select("blue")}
        )
        .rename("EVI")
        .clamp(-1, 1)
    )
    return image.addBands([ndvi, evi])


def get_landsat_collection(
    start_date: str,
    end_date: str,
    geometry: ee.Geometry
) -> ee.ImageCollection:
    """Merge Landsat 8 and 9 C2L2, masked and with indices."""
    l8 = (
        ee.ImageCollection("LANDSAT/LC08/C02/T1_L2")
        .filterDate(start_date, end_date)
        .filterBounds(geometry)
        .map(mask_landsat_c2_l2)
        .map(rename_landsat_8_9)
        .map(add_indices)
    )
    l9 = (
        ee.ImageCollection("LANDSAT/LC09/C02/T1_L2")
        .filterDate(start_date, end_date)
        .filterBounds(geometry)
        .map(mask_landsat_c2_l2)
        .map(rename_landsat_8_9)
        .map(add_indices)
    )
    return l8.merge(l9)

# ------------------------------------------------------------
# 8. Build annual and seasonal NDVI/EVI composites
# ------------------------------------------------------------
# Annual  : full calendar year median
# Dry     : April–September (main signal for native vegetation in SP)
# [IMP-2] Dry-season composite separates native veg from cropland signal

annual_images   = []
dry_images      = []
n_obs_images    = []   # [NEW-1] valid observation count

for year in YEARS:
    # Annual composite
    annual_col = get_landsat_collection(
        f"{year}-01-01", f"{year}-12-31", aoi_geom
    )

    # [NEW-1] Count valid pixels per cell
    n_obs = (
        annual_col.select("NDVI")
        .count()
        .rename("n_obs")
        .set("year", year)
    )
    n_obs_images.append(n_obs)

    annual_comp = (
        annual_col.select(["NDVI", "EVI"]).median()
        .set("year", year)
        .set("system:time_start", ee.Date(f"{year}-01-01").millis())
    )
    # [FIX-2] Apply clip_image_to_aoi
    annual_images.append(clip_image_to_aoi(annual_comp, aoi_geom))

    # [IMP-2] Dry-season composite (April–September)
    dry_col = get_landsat_collection(
        f"{year}-04-01", f"{year}-09-30", aoi_geom
    )
    dry_comp = (
        dry_col.select(["NDVI", "EVI"]).median()
        .set("year", year)
        .set("system:time_start", ee.Date(f"{year}-04-01").millis())
    )
    dry_images.append(clip_image_to_aoi(dry_comp, aoi_geom))

annual_ic = ee.ImageCollection(annual_images)
dry_ic    = ee.ImageCollection(dry_images)
n_obs_ic  = ee.ImageCollection(n_obs_images)

print("Annual and dry-season NDVI/EVI composites created.")

