records = []

for year in YEARS:
    img = annual_ic.filter(ee.Filter.eq("year", year)).first()

    stats = img.reduceRegion(
        reducer=(
            ee.Reducer.mean()
            .combine(ee.Reducer.median(),  sharedInputs=True)
            .combine(ee.Reducer.stdDev(),  sharedInputs=True)
            .combine(ee.Reducer.percentile([10, 25, 75, 90]), sharedInputs=True)
        ),
        geometry=aoi_geom,
        scale=30, maxPixels=1e13, bestEffort=True
    ).getInfo()

    row = {"year": year}
    for key, value in stats.items():
        try:
            row[key] = float(value) if value is not None else np.nan
        except Exception:
            row[key] = np.nan
    records.append(row)

    if year % 5 == 0:
        print(f"  {year} processed...")

