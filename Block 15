print(f"Log file created at: {log_file}")

# ------------------------------------------------------------
# 3. Load integrated NCI-BR dataset
# ------------------------------------------------------------

nci_path = DIRS["processed"] / "nci_br_grid_integrated_index.gpkg"

if not nci_path.exists():
    raise FileNotFoundError("Integrated NCI-BR file not found. Run Block 06 first.")

gdf = gpd.read_file(nci_path)

if gdf.crs is None:
    gdf = gdf.set_crs(CONFIG["output_crs"])

gdf = gdf.to_crs(CONFIG["output_crs"])

print(f"NCI-BR dataset loaded: {len(gdf)} cells")

# ------------------------------------------------------------
# 4. Define NCI-BR component variables
# ------------------------------------------------------------

component_candidates = {
    "native_vegetation": "score_native_vegetation",
    "vegetation_condition": "score_vegetation_condition",
    "hydrological_regulation": "score_hydrological_regulation",
    "low_anthropic_pressure": "score_low_anthropic_pressure",
    "floodplain_function": "score_floodplain_function",
    "vegetation_trend": "score_vegetation_trend"
}

components = {
    k: v for k, v in component_candidates.items()
    if v in gdf.columns
}

if len(components) < 3:
    raise ValueError(f"Too few NCI-BR components found: {components}")

for col in components.values():
    gdf[col] = pd.to_numeric(gdf[col], errors="coerce")

gdf = gdf.dropna(subset=list(components.values())).copy()

print("Components used:")
for k, v in components.items():
    print(f"  {k}: {v}")

# ------------------------------------------------------------
# 5. Baseline weights from Block 06
# ------------------------------------------------------------

baseline_weights = {
    "native_vegetation": 0.30,
    "vegetation_condition": 0.20,
    "hydrological_regulation": 0.20,
    "low_anthropic_pressure": 0.15,
    "floodplain_function": 0.10,
    "vegetation_trend": 0.05
}

baseline_weights = {
    k: baseline_weights[k]
    for k in components.keys()
}

# Renormalize if some components are missing
total_w = sum(baseline_weights.values())
baseline_weights = {k: v / total_w for k, v in baseline_weights.items()}

print("\nBaseline weights used:")
print(baseline_weights)

# ------------------------------------------------------------
# 6. Helper functions
# ------------------------------------------------------------

def minmax_0_100(x):
    x = np.asarray(x, dtype=float)
    xmin = np.nanmin(x)
    xmax = np.nanmax(x)

    if xmax == xmin:
        return np.full_like(x, np.nan)

    return (x - xmin) / (xmax - xmin) * 100

def compute_weighted_index(df, components, weights):
    score = np.zeros(len(df), dtype=float)

    for comp_name, col in components.items():
        score += df[col].values * weights[comp_name]

    return minmax_0_100(score)

# ------------------------------------------------------------
# 7. Baseline recomputation
# ------------------------------------------------------------

gdf["NCI_BR_recomputed_baseline"] = compute_weighted_index(
    gdf,
    components,
    baseline_weights
)

# ------------------------------------------------------------
# 8. Monte Carlo weight perturbation
# ------------------------------------------------------------
# This does NOT create environmental data.
# It only tests how sensitive the NCI-BR ranking is to weight uncertainty.

N_SIM = 1000
RANDOM_SEED = 42

rng = np.random.default_rng(RANDOM_SEED)

component_names = list(components.keys())
baseline_weight_vector = np.array([baseline_weights[c] for c in component_names])

# Dirichlet concentration controls how strongly simulations remain near baseline.
# Higher = less variation; lower = more variation.
DIRICHLET_CONCENTRATION = 80

alpha = baseline_weight_vector * DIRICHLET_CONCENTRATION

simulated_indices = np.zeros((len(gdf), N_SIM), dtype=np.float32)
weight_records = []

print(f"\nRunning Monte Carlo sensitivity analysis: {N_SIM} simulations...")

for i in range(N_SIM):
    sampled_weights = rng.dirichlet(alpha)

    weights = {
        comp: sampled_weights[j]
        for j, comp in enumerate(component_names)
    }

    simulated_indices[:, i] = compute_weighted_index(
        gdf,
        components,
        weights
    )

    row = {"simulation": i}
    row.update({f"weight_{k}": v for k, v in weights.items()})
    weight_records.append(row)

weights_df = pd.DataFrame(weight_records)

# ------------------------------------------------------------
# 9. Uncertainty metrics per grid cell
# ------------------------------------------------------------

gdf["NCI_BR_mc_mean"] = np.nanmean(simulated_indices, axis=1)
gdf["NCI_BR_mc_median"] = np.nanmedian(simulated_indices, axis=1)
gdf["NCI_BR_mc_std"] = np.nanstd(simulated_indices, axis=1)
gdf["NCI_BR_mc_p05"] = np.nanpercentile(simulated_indices, 5, axis=1)
gdf["NCI_BR_mc_p25"] = np.nanpercentile(simulated_indices, 25, axis=1)
gdf["NCI_BR_mc_p75"] = np.nanpercentile(simulated_indices, 75, axis=1)
gdf["NCI_BR_mc_p95"] = np.nanpercentile(simulated_indices, 95, axis=1)
gdf["NCI_BR_mc_iqr"] = gdf["NCI_BR_mc_p75"] - gdf["NCI_BR_mc_p25"]
gdf["NCI_BR_mc_range90"] = gdf["NCI_BR_mc_p95"] - gdf["NCI_BR_mc_p05"]

# Hotspot robustness
baseline_q75 = gdf["NCI_BR_recomputed_baseline"].quantile(0.75)
baseline_q90 = gdf["NCI_BR_recomputed_baseline"].quantile(0.90)

gdf["prob_high_nci_q75"] = (simulated_indices >= baseline_q75).mean(axis=1)
gdf["prob_very_high_nci_q90"] = (simulated_indices >= baseline_q90).mean(axis=1)

def classify_robustness(p):
    if p >= 0.90:
        return "Very robust high-NCI"
    elif p >= 0.75:
        return "Robust high-NCI"
    elif p >= 0.50:
        return "Moderately robust high-NCI"
    elif p >= 0.25:
        return "Unstable high-NCI"
    else:
        return "Not robust high-NCI"

gdf["high_nci_robustness_class"] = gdf["prob_high_nci_q75"].apply(classify_robustness)

# ------------------------------------------------------------
# 10. Sensitivity of ranking
# ------------------------------------------------------------

baseline_rank = gdf["NCI_BR_recomputed_baseline"].rank(ascending=False)

rank_matrix = np.zeros((len(gdf), N_SIM), dtype=np.float32)

for i in range(N_SIM):
    rank_matrix[:, i] = pd.Series(
        simulated_indices[:, i]
    ).rank(ascending=False).values

gdf["rank_baseline"] = baseline_rank.values
gdf["rank_mc_mean"] = np.nanmean(rank_matrix, axis=1)
gdf["rank_mc_std"] = np.nanstd(rank_matrix, axis=1)
gdf["rank_mc_p05"] = np.nanpercentile(rank_matrix, 5, axis=1)
gdf["rank_mc_p95"] = np.nanpercentile(rank_matrix, 95, axis=1)

# ------------------------------------------------------------
# 11. Component influence diagnostics
# ------------------------------------------------------------

component_corr_records = []

for comp_name, col in components.items():
    corr = np.corrcoef(
        gdf[col].values,
        gdf["NCI_BR_recomputed_baseline"].values
    )[0, 1]

    component_corr_records.append({
        "component": comp_name,
        "column": col,
        "correlation_with_baseline_NCI": corr,
        "baseline_weight": baseline_weights[comp_name]
    })

component_corr_df = pd.DataFrame(component_corr_records)

# ------------------------------------------------------------
# 12. Summary tables
# ------------------------------------------------------------

uncertainty_summary = pd.DataFrame([
    {
        "metric": "mean_mc_std",
        "value": gdf["NCI_BR_mc_std"].mean(),
        "unit": "NCI points"
    },
    {
        "metric": "median_mc_std",
        "value": gdf["NCI_BR_mc_std"].median(),
        "unit": "NCI points"
    },
    {
        "metric": "mean_mc_iqr",
        "value": gdf["NCI_BR_mc_iqr"].mean(),
        "unit": "NCI points"
    },
    {
        "metric": "mean_prob_high_nci_q75",
        "value": gdf["prob_high_nci_q75"].mean(),
        "unit": "probability"
    },
    {
        "metric": "cells_very_robust_high_nci",
        "value": int((gdf["high_nci_robustness_class"] == "Very robust high-NCI").sum()),
        "unit": "cells"
    },
    {
        "metric": "cells_robust_or_very_robust_high_nci",
        "value": int(gdf["high_nci_robustness_class"].isin([
            "Very robust high-NCI",
            "Robust high-NCI"
        ]).sum()),
        "unit": "cells"
    },
    {
        "metric": "monte_carlo_simulations",
        "value": N_SIM,
        "unit": "runs"
    }
])

robustness_summary = (
    gdf.groupby("high_nci_robustness_class")
    .agg(
        n_cells=("grid_id", "count"),
        mean_NCI_BR=("NCI_BR_recomputed_baseline", "mean"),
        mean_uncertainty_std=("NCI_BR_mc_std", "mean"),
        mean_prob_high_nci=("prob_high_nci_q75", "mean")
    )
