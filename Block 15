# 7. Helper functions
# ------------------------------------------------------------

def minmax_0_100(x):
    x = np.asarray(x, dtype=float)
    xmin = np.nanmin(x)
    xmax = np.nanmax(x)

    if not np.isfinite(xmin) or not np.isfinite(xmax) or xmax == xmin:
        return np.full_like(x, np.nan, dtype=float)

    return (x - xmin) / (xmax - xmin) * 100


def compute_weighted_index(df, components, weights):
    score = np.zeros(len(df), dtype=float)

    for comp_name, col in components.items():
        score += df[col].values * weights[comp_name]

    return minmax_0_100(score)


def md5_checksum(fp: Path) -> str:
    h = hashlib.md5()
    with open(fp, "rb") as f:
        for chunk in iter(lambda: f.read(8192), b""):
            h.update(chunk)
    return h.hexdigest()


