    )


def format_map_axis(ax):
    ax.set_xlim(map_extent[0], map_extent[1])
    ax.set_ylim(map_extent[2], map_extent[3])
    ax.set_aspect("equal")
    ax.set_axis_off()


def safe_choropleth(gdf, column, ax, cmap, title,
                    vmin=None, vmax=None, legend=True,
                    cbar_label=None):
    if column not in gdf.columns or gdf[column].dropna().empty:
        gdf.plot(ax=ax, color="#eeeeee", linewidth=0)
        ax.text(
            0.5, 0.5, f"No data\n{column}",
            transform=ax.transAxes,
            ha="center",
            va="center",
            fontsize=8,
            color="#555555",
            bbox=dict(facecolor="white", edgecolor="none", alpha=0.85)
        )
        ax.set_title(title, loc="left", fontsize=10, fontweight="bold")
        return

    valid = gdf[column].dropna()
    vmin = float(valid.min()) if vmin is None else vmin
    vmax = float(valid.max()) if vmax is None else vmax

    gdf.plot(
        column=column,
        ax=ax,
        cmap=cmap,
        linewidth=0,
        legend=legend,
        vmin=vmin,
        vmax=vmax,
        missing_kwds={"color": "#eeeeee"},
        legend_kwds={
            "shrink": 0.72,
            "pad": 0.02,
            "label": cbar_label if cbar_label else column
        } if legend else None
    )

    overlay_boundary(ax, muni_plot)
    format_map_axis(ax)
    ax.set_title(title, loc="left", fontsize=10, fontweight="bold")


