    baseline_weights
)

# ------------------------------------------------------------
# 9. Monte Carlo weight perturbation
# ------------------------------------------------------------

N_SIM = 1000
RANDOM_SEED = 42
DIRICHLET_CONCENTRATION = 80

rng = np.random.default_rng(RANDOM_SEED)

component_names = list(components.keys())
baseline_weight_vector = np.array([baseline_weights[c] for c in component_names])
alpha = baseline_weight_vector * DIRICHLET_CONCENTRATION

simulated_indices = np.zeros((len(gdf), N_SIM), dtype=np.float32)
weight_records = []

print(f"\nRunning Monte Carlo sensitivity analysis: {N_SIM} simulations...")

for i in range(N_SIM):
    sampled_weights = rng.dirichlet(alpha)

    weights = {
        comp: sampled_weights[j]
        for j, comp in enumerate(component_names)
    }

    simulated_indices[:, i] = compute_weighted_index(
        gdf,
        components,
        weights
    )

    row = {"simulation": i}
    row.update({f"weight_{k}": v for k, v in weights.items()})
    weight_records.append(row)

weights_df = pd.DataFrame(weight_records)

# ------------------------------------------------------------
# 10. Uncertainty metrics per grid cell
# ------------------------------------------------------------

gdf["NCI_BR_mc_mean"] = np.nanmean(simulated_indices, axis=1)
gdf["NCI_BR_mc_median"] = np.nanmedian(simulated_indices, axis=1)
gdf["NCI_BR_mc_std"] = np.nanstd(simulated_indices, axis=1)
gdf["NCI_BR_mc_p05"] = np.nanpercentile(simulated_indices, 5, axis=1)
gdf["NCI_BR_mc_p25"] = np.nanpercentile(simulated_indices, 25, axis=1)
gdf["NCI_BR_mc_p75"] = np.nanpercentile(simulated_indices, 75, axis=1)
gdf["NCI_BR_mc_p95"] = np.nanpercentile(simulated_indices, 95, axis=1)
gdf["NCI_BR_mc_iqr"] = gdf["NCI_BR_mc_p75"] - gdf["NCI_BR_mc_p25"]
gdf["NCI_BR_mc_range90"] = gdf["NCI_BR_mc_p95"] - gdf["NCI_BR_mc_p05"]

baseline_q75 = gdf["NCI_BR_recomputed_baseline"].quantile(0.75)
baseline_q90 = gdf["NCI_BR_recomputed_baseline"].quantile(0.90)

gdf["prob_high_nci_q75"] = (simulated_indices >= baseline_q75).mean(axis=1)
gdf["prob_very_high_nci_q90"] = (simulated_indices >= baseline_q90).mean(axis=1)


def classify_robustness(p):
    if p >= 0.90:
        return "Very robust high-NCI"
    elif p >= 0.75:
        return "Robust high-NCI"
    elif p >= 0.50:
        return "Moderately robust high-NCI"
    elif p >= 0.25:
        return "Unstable high-NCI"
    else:
        return "Not robust high-NCI"


gdf["high_nci_robustness_class"] = gdf["prob_high_nci_q75"].apply(classify_robustness)

# ------------------------------------------------------------
# 11. Sensitivity of ranking
# ------------------------------------------------------------

baseline_rank = gdf["NCI_BR_recomputed_baseline"].rank(ascending=False)

rank_matrix = np.zeros((len(gdf), N_SIM), dtype=np.float32)

for i in range(N_SIM):
    rank_matrix[:, i] = pd.Series(
        simulated_indices[:, i]
    ).rank(ascending=False).values

gdf["rank_baseline"] = baseline_rank.values
gdf["rank_mc_mean"] = np.nanmean(rank_matrix, axis=1)
gdf["rank_mc_std"] = np.nanstd(rank_matrix, axis=1)
gdf["rank_mc_p05"] = np.nanpercentile(rank_matrix, 5, axis=1)
gdf["rank_mc_p95"] = np.nanpercentile(rank_matrix, 95, axis=1)

